---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ContactForm from '../../components/ContactForm.astro';
import { getAllLangStaticPaths, getLocalizedPath, getLocalizedSiteAddress, siteContactEmails, siteCopy, type SiteLang } from '../../data/i18n';

export function getStaticPaths() {
  return getAllLangStaticPaths();
}

const { lang } = Astro.params as { lang: SiteLang };
const copy = siteCopy[lang];
const localizedAddress = getLocalizedSiteAddress(lang);
const contactInfoCopy = {
  en: { title: 'Direct business contact', phone: 'Phone', email: 'Email', location: 'Location' },
  zh: { title: '直接商务联系', phone: '手机', email: '邮箱', location: '地址' },
  ru: { title: 'Прямой деловой контакт', phone: 'Телефон', email: 'Email', location: 'Адрес' },
  de: { title: 'Direkter Geschäftskontakt', phone: 'Telefon', email: 'E-Mail', location: 'Adresse' },
  fr: { title: 'Contact commercial direct', phone: 'Téléphone', email: 'E-mail', location: 'Adresse' },
  es: { title: 'Contacto comercial directo', phone: 'Teléfono', email: 'Correo electrónico', location: 'Dirección' }
} as const;
const contactInfo = contactInfoCopy[lang];
---

<BaseLayout
  lang={lang}
  pathname="/contact"
  title={`Contact Ascent Crane | ${copy.contact.title}`}
  description={copy.contact.description}
  canonicalURL={`https://ascentcrane.com${getLocalizedPath(lang, '/contact')}`}
  ogImage="https://ascentcrane.com/assets/images/hero.png"
>
  <Navbar lang={lang} currentPath={Astro.url.pathname} />
  <main class="bg-slate-50 pt-28">
    <section class="mx-auto max-w-screen-xl px-4 py-16 lg:px-6 lg:py-24">
      <div class="mb-12 max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-orange">{copy.contact.eyebrow}</p>
        <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-brand-navy sm:text-5xl">{copy.contact.title}</h1>
        <p class="mt-4 text-lg leading-8 text-slate-600">{copy.contact.description}</p>
      </div>
      <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr]">
        <ContactForm lang={lang} />
        <aside class="rounded-[28px] border border-slate-200 bg-white p-8 text-slate-900 shadow-[0_20px_70px_rgba(15,39,68,0.08)]">
          <h2 class="text-2xl font-bold text-brand-navy">{contactInfo.title}</h2>
          <div class="mt-6 space-y-5 text-sm leading-7 text-slate-600">
            <div><p class="font-semibold text-slate-900">{contactInfo.phone}</p><p>+86 15903067111</p></div>
            <div>
              <p class="font-semibold text-slate-900">{contactInfo.email}</p>
              {siteContactEmails.map((email) => (
                <p>{email}</p>
              ))}
            </div>
            <div><p class="font-semibold text-slate-900">{contactInfo.location}</p><p>{localizedAddress}</p></div>
          </div>
        </aside>
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</BaseLayout>
