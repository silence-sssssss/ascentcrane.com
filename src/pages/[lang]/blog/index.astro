---
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { getAllLangStaticPaths, getLocalizedPath, siteCopy, type SiteLang } from '../../../data/i18n';
import { getBlogImage } from '../../../data/contentMedia';
import { getMappedContentImage } from '../../../data/imageAssets';
import { getBlogSeoDescription } from '../../../data/seo';

export function getStaticPaths() {
  return getAllLangStaticPaths();
}

const blogModules = import.meta.glob('../../../content/blog/**/*.md', { eager: true });
const { lang } = Astro.params as { lang: SiteLang };
const copy = siteCopy[lang];
const blogListCopy = {
  en: {
    description: 'Publishing-ready article slot for future multilingual SEO expansion.',
    heroTag: 'Editorial Matrix',
    heroStats: ['5 core topics', '6 languages', 'SEO-ready technical themes'],
    featuredTitle: 'Latest intelligence for industrial buyers',
    cta: 'Read Article'
  },
  zh: {
    description: '此处为后续多语言 SEO 长文内容预留的文章卡片位。',
    heroTag: '内容矩阵',
    heroStats: ['5 个核心主题', '6 种语言', '面向 SEO 的技术选题'],
    featuredTitle: '面向工业采购商的最新内容',
    cta: '阅读文章'
  },
  ru: {
    description: 'Подготовленный слот статьи для дальнейшего многоязычного SEO-расширения.',
    heroTag: 'Контент-матрица',
    heroStats: ['5 ключевых тем', '6 языков', 'SEO-ориентированные статьи'],
    featuredTitle: 'Свежие материалы для промышленных покупателей',
    cta: 'Читать статью'
  },
  de: {
    description: 'Vorbereiteter Artikelplatz für den weiteren mehrsprachigen SEO-Ausbau.',
    heroTag: 'Content-Matrix',
    heroStats: ['5 Kernthemen', '6 Sprachen', 'SEO-fähige Fachthemen'],
    featuredTitle: 'Neueste Inhalte für industrielle Einkäufer',
    cta: 'Artikel lesen'
  },
  fr: {
    description: 'Emplacement d’article prêt à publier pour l’extension SEO multilingue future.',
    heroTag: 'Matrice éditoriale',
    heroStats: ['5 sujets clés', '6 langues', 'Thèmes techniques prêts pour le SEO'],
    featuredTitle: 'Derniers contenus pour acheteurs industriels',
    cta: 'Lire l’article'
  },
  es: {
    description: 'Espacio de artículo listo para futuras ampliaciones SEO multilingües.',
    heroTag: 'Matriz editorial',
    heroStats: ['5 temas clave', '6 idiomas', 'Temas técnicos listos para SEO'],
    featuredTitle: 'Últimos contenidos para compradores industriales',
    cta: 'Leer artículo'
  }
} as const;
const blogListText = blogListCopy[lang];
const articles = Object.values(blogModules)
  .map((module) => (module as { frontmatter: Record<string, string | string[]> }).frontmatter)
  .filter((article) => article.lang === lang)
  .sort((a, b) => a.slug.localeCompare(b.slug))
  .slice(0, 6);

---

<BaseLayout
  lang={lang}
  pathname="/blog"
  title={`Blog | ${copy.blog.title}`}
  description={copy.blog.description}
  canonicalURL={`https://ascentcrane.com${getLocalizedPath(lang, '/blog')}`}
  ogImage="https://ascentcrane.com/assets/images/hero.png"
>
  <Navbar lang={lang} currentPath={Astro.url.pathname} />
  <main class="bg-slate-50 pt-28">
    <section class="border-b border-slate-200 bg-white">
      <div class="mx-auto grid max-w-[1280px] gap-8 px-4 py-16 lg:grid-cols-[1.1fr_0.9fr] lg:px-8 lg:py-20">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-orange">{copy.blog.eyebrow}</p>
          <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-brand-navy sm:text-5xl">{copy.blog.title}</h1>
          <p class="mt-5 text-lg leading-8 text-slate-600">{copy.blog.description}</p>
        </div>
        <div class="rounded-[30px] border border-slate-200 bg-gradient-to-br from-brand-navy via-blue-900 to-slate-900 p-8 text-white shadow-[0_24px_80px_rgba(15,39,68,0.20)]">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-orange-200">{blogListText.heroTag}</p>
          <h2 class="mt-4 text-2xl font-bold">{blogListText.featuredTitle}</h2>
          <p class="mt-3 text-sm leading-7 text-slate-200">{blogListText.description}</p>
          <div class="mt-6 grid gap-3 sm:grid-cols-3 lg:grid-cols-1 xl:grid-cols-3">
            {blogListText.heroStats.map((stat) => (
              <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-4 text-sm font-medium text-slate-100">{stat}</div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-[1280px] px-4 py-16 lg:px-8 lg:py-20">
      <div class="grid gap-8 lg:grid-cols-3">
        {articles.map((article) => (
          <article class="overflow-hidden rounded-[30px] border border-slate-200 bg-white text-slate-900 shadow-sm transition hover:-translate-y-1 hover:shadow-[0_24px_80px_rgba(15,39,68,0.14)]">
            <Image src={getMappedContentImage(typeof article.image === 'string' ? article.image : getBlogImage(String(article.slug)))} alt={String(article.title)} class="h-48 w-full object-cover" format="avif" quality="mid" widths={[400,800,1200]} sizes="(min-width: 1024px) 30vw, 100vw" width={1200} height={675} loading="lazy" />
            <div class="p-7">
              <h2 class="text-xl font-bold leading-8 text-brand-navy">{String(article.title)}</h2>
              <p class="mt-4 text-sm leading-7 text-slate-600">{getBlogSeoDescription(String(article.title), String(article.description), lang)}</p>
              <a href={getLocalizedPath(lang, `/blog/${String(article.slug)}`)} class="mt-6 inline-flex items-center text-sm font-semibold text-primary-700 transition hover:text-primary-800">{blogListText.cta}</a>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</BaseLayout>
