---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { getAllLangStaticPaths, getLocalizedPath, siteCopy, type SiteLang } from '../../../data/i18n';

export function getStaticPaths() {
  return getAllLangStaticPaths();
}

const { lang } = Astro.params as { lang: SiteLang };
const copy = siteCopy[lang];
const topics = [
  'How to choose the right portable gantry crane capacity',
  'When a scissor lift is better than a traditional access platform',
  'What overseas buyers should confirm before ordering lifting equipment'
];
---

<BaseLayout
  lang={lang}
  pathname="/blog"
  title={`Blog | ${copy.blog.title}`}
  description={copy.blog.description}
  canonicalURL={`https://ascentcrane.com${getLocalizedPath(lang, '/blog')}`}
  ogImage="https://ascentcrane.com/assets/images/hero.png"
>
  <Navbar lang={lang} currentPath={Astro.url.pathname} />
  <main class="bg-slate-50 pt-28">
    <section class="mx-auto max-w-screen-xl px-4 py-16 lg:px-6 lg:py-24">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-orange">{copy.blog.eyebrow}</p>
        <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-brand-navy sm:text-5xl">{copy.blog.title}</h1>
        <p class="mt-5 text-lg leading-8 text-slate-600">{copy.blog.description}</p>
      </div>
      <div class="mt-12 grid gap-6">
        {topics.map((topic) => (
          <article class="rounded-[24px] border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-xl font-bold text-brand-navy">{topic}</h2>
            <p class="mt-3 text-sm text-slate-600">Publishing-ready article slot for future multilingual SEO expansion.</p>
          </article>
        ))}
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</BaseLayout>
