---
import ContentLayout from '../../../layouts/ContentLayout.astro';
import { supportedLangs, getLocalizedPath, type SiteLang } from '../../../data/i18n';

export async function getStaticPaths() {
  const blogModules = import.meta.glob('../../../content/blog/*.md');
  const entries = await Promise.all(
    Object.values(blogModules).map(async (resolver) => {
      const mod = (await resolver()) as {
        frontmatter: Record<string, string>;
        default: unknown;
      };

      return {
        data: mod.frontmatter,
        Content: mod.default
      };
    })
  );

  return entries
    .filter((entry) => supportedLangs.includes(entry.data.lang as SiteLang))
    .map((entry) => ({
      params: { lang: entry.data.lang, slug: entry.data.slug },
      props: { article: entry }
    }));
}

const { lang, slug } = Astro.params as { lang: SiteLang; slug: string };
const { article } = Astro.props as {
  article: {
    data: Record<string, string>;
    Content: unknown;
  };
};

const Content = article.Content;
const { title, description } = article.data;
const copy = {
  en: {
    eyebrow: 'Article Detail',
    tocTitle: 'Table of Contents',
    quote: 'Get a Quote',
    readyTitle: 'Ready to Start?',
    readyText: 'If this article matches your project direction, send your requirements and we will help you map product options and quotation steps.',
    whatsappLabel: 'WhatsApp'
  },
  zh: {
    eyebrow: '文章详情',
    tocTitle: '目录',
    quote: '获取报价',
    readyTitle: '准备开始？',
    readyText: '如果这篇文章对应你的项目方向，请把需求发给我们，我们会协助梳理产品选型与报价路径。',
    whatsappLabel: 'WhatsApp'
  },
  ru: {
    eyebrow: 'Детали статьи',
    tocTitle: 'Содержание',
    quote: 'Получить предложение',
    readyTitle: 'Готовы начать?',
    readyText: 'Если материал соответствует вашему проекту, отправьте требования, и мы поможем подобрать оборудование и путь к коммерческому предложению.',
    whatsappLabel: 'WhatsApp'
  },
  de: {
    eyebrow: 'Artikeldetail',
    tocTitle: 'Inhaltsverzeichnis',
    quote: 'Angebot erhalten',
    readyTitle: 'Bereit zu starten?',
    readyText: 'Wenn der Artikel zu Ihrem Projekt passt, senden Sie uns Ihre Anforderungen und wir strukturieren Produktauswahl und Angebotsweg.',
    whatsappLabel: 'WhatsApp'
  },
  fr: {
    eyebrow: 'Détail article',
    tocTitle: 'Sommaire',
    quote: 'Obtenir un devis',
    readyTitle: 'Prêt à démarrer ?',
    readyText: 'Si cet article correspond à votre projet, partagez votre besoin et nous vous aiderons à structurer le choix produit et le parcours devis.',
    whatsappLabel: 'WhatsApp'
  },
  es: {
    eyebrow: 'Detalle del artículo',
    tocTitle: 'Tabla de contenido',
    quote: 'Obtener cotización',
    readyTitle: '¿Listo para empezar?',
    readyText: 'Si este artículo encaja con su proyecto, envíenos sus requisitos y le ayudaremos a estructurar la selección de producto y la ruta de cotización.',
    whatsappLabel: 'WhatsApp'
  }
} as const;

const text = copy[lang];
const tocItems = [
  { id: 'overview', text: text.eyebrow, level: 2 },
  { id: 'content-body', text: title, level: 2 },
  { id: 'image-blocks', text: 'Image Blocks', level: 2 }
] as const;
const quickLinksCopy = {
  en: { title: 'Quick Access', products: 'Products', blog: 'Blog', contact: 'Contact' },
  zh: { title: '快捷入口', products: '产品中心', blog: '博客', contact: '联系我们' },
  ru: { title: 'Быстрый доступ', products: 'Продукция', blog: 'Блог', contact: 'Контакты' },
  de: { title: 'Schnellzugriff', products: 'Produkte', blog: 'Blog', contact: 'Kontakt' },
  fr: { title: 'Accès rapide', products: 'Produits', blog: 'Blog', contact: 'Contact' },
  es: { title: 'Acceso rápido', products: 'Productos', blog: 'Blog', contact: 'Contacto' }
} as const;
---

<ContentLayout
  lang={lang}
  pathname={`/blog/${slug}`}
  title={`${title} | Ascent Crane Blog`}
  description={description}
  canonicalURL={`https://ascentcrane.com${getLocalizedPath(lang, `/blog/${slug}`)}`}
  ogImage="https://ascentcrane.com/assets/images/hero.png"
  heroEyebrow={text.eyebrow}
  heroTitle={title}
  heroDescription={description}
  tocItems={tocItems}
  ctaCopy={{
    tocTitle: text.tocTitle,
    getQuote: text.quote,
    readyTitle: text.readyTitle,
    readyText: text.readyText,
    whatsappLabel: text.whatsappLabel
  }}
  quickLinksCopy={quickLinksCopy[lang]}
  stickyHref={getLocalizedPath(lang, '/contact')}
  stickyLabel={title}
>
  <section id="overview">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-orange">{text.eyebrow}</p>
    <h2 class="mt-3 text-2xl font-bold text-brand-navy">{title}</h2>
  </section>

  <article id="content-body" class="prose prose-slate mt-10 max-w-none prose-headings:scroll-mt-28 prose-headings:text-brand-navy prose-a:text-primary-700">
    <Content />
  </article>

  <section id="image-blocks" class="mt-10 grid gap-6">
    <div class="h-64 rounded-[24px] border border-slate-200 bg-slate-100 shadow-sm"></div>
    <div class="h-64 rounded-[24px] border border-slate-200 bg-slate-100 shadow-sm"></div>
  </section>
</ContentLayout>
