---

<BaseLayout
  lang={lang}
  pathname="/"
  title={copy.home.title}
  description={copy.home.description}
  canonicalURL={`https://ascentcrane.com${getLocalizedPath(lang, '/')}`}
  ogImage="https://ascentcrane.com/assets/images/hero.png"
>
  <Navbar lang={lang} currentPath={Astro.url.pathname} />
  <main class="bg-brand-cold pt-24">
    <HeroCarousel lang={lang} />

    <ExportFeatures lang={lang} />

    <div class="pt-[60px]">
      <GlobalReach lang={lang} />
    </div>

    <section class="mx-auto max-w-[1280px] px-4 py-7 lg:px-8 lg:py-8">
      <div class="max-w-3xl">
        <p class="industrial-eyebrow">{portalCopy.categoriesTitle}</p>
        <h2 class="mt-4 text-3xl font-extrabold tracking-tighter text-brand-navy sm:text-4xl">{copy.products.title}</h2>
        <p class="mt-4 text-base leading-8 text-slate-600">{portalCopy.categoriesDescription}</p>
      </div>
      <div class="mt-5 grid gap-6 lg:grid-cols-3">
        {portalCopy.categories.map((category) => (
          <article class="overflow-hidden border border-slate-200 bg-white text-slate-900">
            <div class="relative bg-slate-300" style={`aspect-ratio: ${getImageAspectRatio(category.image)};`}>
              <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${category.image}')`}></div>
              <div class="absolute inset-0 bg-brand-navy/55"></div>
              <div class="relative flex h-full items-end p-6">
                <h3 class="text-2xl font-extrabold tracking-tight text-white">{category.title}</h3>
              </div>
            </div>
            <div class="grid gap-px border-t border-slate-200 bg-slate-200">
              <div class="bg-white px-6 py-5">
                <p class="text-sm leading-7 text-slate-600">{category.description}</p>
              </div>
              <div class="bg-white px-6 py-4">
                <a href={getLocalizedPath(lang, category.href)} class="inline-flex items-center text-sm font-bold uppercase tracking-[0.08em] text-brand-navy transition hover:text-brand-orange">{portalCopy.explore}</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="border-y border-slate-200 bg-white">
      <div class="mx-auto max-w-[1280px] px-4 py-7 lg:px-8 lg:py-8">
        <div class="max-w-3xl">
          <p class="industrial-eyebrow">{portalCopy.articlesTitle}</p>
          <h2 class="mt-4 text-3xl font-extrabold tracking-tighter text-brand-navy sm:text-4xl">{copy.blog.title}</h2>
          <p class="mt-4 text-base leading-8 text-slate-600">{portalCopy.articlesDescription}</p>
        </div>
        <div class="mt-5 grid gap-6 lg:grid-cols-3">
          {portalCopy.articles.map((article) => (
            <article class="overflow-hidden border border-slate-200 bg-brand-cold text-slate-900">
              <div class="relative aspect-[16/9] w-full overflow-hidden bg-slate-300">
                <Image
                  src={getMappedContentImage(article.image)}
                  alt={article.title}
                  class="absolute inset-0 h-full w-full object-contain"
                  format="avif"
                  quality="mid"
                  widths={[400, 800, 1200]}
                  sizes="(min-width: 1024px) 33vw, 100vw"
                  width={1200}
                  height={675}
                  loading="lazy"
                />
                <div class="pointer-events-none absolute inset-0 bg-brand-navy/35"></div>
              </div>
              <div class="grid gap-px border-t border-slate-200 bg-slate-200">
                <div class="bg-white px-6 py-5">
                  <h3 class="text-xl font-extrabold leading-8 tracking-tight text-brand-navy">{article.title}</h3>
                  <p class="mt-4 text-sm leading-7 text-slate-600">{article.description}</p>
                </div>
                <div class="bg-white px-6 py-4">
                  <a href={getLocalizedPath(lang, article.href)} class="inline-flex items-center text-sm font-bold uppercase tracking-[0.08em] text-brand-navy transition hover:text-brand-orange">{portalCopy.explore}</a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="border-b border-slate-200 bg-white">
      <div class="mx-auto max-w-[1280px] px-4 py-7 lg:px-8 lg:py-8">
        <div class="max-w-3xl">
          <p class="industrial-eyebrow">{portalCopy.platformsEyebrow}</p>
          <h2 class="mt-4 text-3xl font-extrabold tracking-tighter text-brand-navy sm:text-4xl">{portalCopy.platformsTitle}</h2>
          <p class="mt-4 text-base leading-8 text-slate-600">{portalCopy.platformsDescription}</p>
        </div>

        <div class="mt-5 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {localizedPlatforms.map((platform) => (
            <a
              href={platform.href}
              target="_blank"
              rel="nofollow noopener noreferrer"
              class="group block border border-slate-200 bg-brand-cold p-6 text-slate-900 transition duration-300 hover:-translate-y-1 hover:border-brand-orange hover:bg-white"
            >
              <div class="platform-logo-card flex h-full flex-col justify-between gap-6 grayscale transition duration-300 group-hover:grayscale-0">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <p class="text-xs font-bold uppercase tracking-[0.24em] text-slate-400 transition group-hover:text-brand-orange">{portalCopy.platformBadge}</p>
                    <h3 class="mt-3 text-xl font-extrabold tracking-tight text-brand-navy">{platform.name}</h3>
                  </div>
                  <div class={`inline-flex min-w-[88px] justify-center bg-gradient-to-r ${platform.accent} px-4 py-3 text-lg font-black uppercase tracking-[0.18em] text-white shadow-[0_14px_32px_rgba(15,39,68,0.18)]`}>
                    {platform.mark}
                  </div>
                </div>

                <div class="border-t border-slate-200 pt-5">
                  <p class="text-sm leading-7 text-slate-600">{platform.description}</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</BaseLayout>
