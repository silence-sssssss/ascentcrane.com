      { title: 'Grúas pórtico portátiles', description: 'Sistemas flexibles para talleres, almacenes y servicio en campo.', image: '/assets/images/hero.png', href: '/products' },
      { title: 'Plataformas hidráulicas', description: 'Soluciones estables para mantenimiento en altura y posicionamiento de materiales.', image: '/assets/images/feature-1.png', href: '/products' },
      { title: 'Sistemas para proyectos a medida', description: 'Paquetes configurados para exportación, EPC y distribuidores.', image: '/assets/images/feature-2.png', href: '/solutions' }
    ],
    explore: 'Explorar serie',
    articlesTitle: 'Latest Articles',
    articlesDescription: 'Una matriz de contenidos pensada para educación de compra, comparación técnica y conversión.',
    articles: [
      { title: 'Cómo elegir la capacidad correcta de una grúa pórtico portátil', description: 'Un marco práctico para relacionar capacidad, luz y ciclo de trabajo.', image: '/assets/images/feature-1.png', href: '/blog' },
      { title: 'Prioridades de mantenimiento para equipos hidráulicos', description: 'Qué inspeccionar primero para reducir paradas y prolongar la vida útil.', image: '/assets/images/feature-2.png', href: '/blog' },
      { title: 'Qué debe confirmar un comprador internacional antes de ordenar', description: 'Una guía de verificación para documentos, normas, alimentación y envío.', image: '/assets/images/hero.png', href: '/blog' }
    ]
  }
} as const;
const portalCopy = homePortalCopy[lang];
---

<BaseLayout
  lang={lang}
  pathname="/"
  title={copy.home.title}
  description={copy.home.description}
  canonicalURL={`https://ascentcrane.com${getLocalizedPath(lang, '/')}`}
  ogImage="https://ascentcrane.com/assets/images/hero.png"
>
  <Navbar lang={lang} currentPath={Astro.url.pathname} />
  <main class="bg-slate-50 pt-24">
    <section class="border-b border-slate-200 bg-white">
      <div class="mx-auto grid max-w-[1280px] gap-10 px-4 py-16 lg:grid-cols-[1.15fr_0.85fr] lg:px-8 lg:py-20">
        <div>
          <span class="inline-flex items-center rounded-full bg-orange-50 px-3 py-1 text-sm font-medium text-brand-orange ring-1 ring-inset ring-orange-200">{copy.home.eyebrow}</span>
          <h1 class="mt-6 max-w-3xl text-4xl font-extrabold leading-tight tracking-tight text-brand-navy md:text-5xl xl:text-6xl">{copy.home.title}</h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">{copy.home.description}</p>
          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            <a href={getLocalizedPath(lang, '/products')} class="inline-flex items-center justify-center rounded-xl bg-brand-orange px-6 py-3.5 text-sm font-semibold text-white shadow-sm transition hover:bg-orange-600 hover:text-white focus:outline-none focus:ring-4 focus:ring-orange-200 focus:text-white">{copy.home.primaryCta}</a>
            <a href={getLocalizedPath(lang, '/blog')} class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-6 py-3.5 text-sm font-semibold text-slate-900 transition hover:bg-slate-100 hover:text-slate-900 focus:outline-none focus:ring-4 focus:ring-slate-100 focus:text-slate-900">Blog</a>
          </div>
        </div>
        <div class="rounded-[32px] border border-slate-200 bg-gradient-to-br from-brand-navy via-blue-900 to-slate-900 p-8 text-white shadow-[0_24px_80px_rgba(15,39,68,0.22)]">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-orange-200">{portalCopy.trustTitle}</p>
          <div class="mt-8 grid gap-5 sm:grid-cols-3 lg:grid-cols-1 xl:grid-cols-3">
            {portalCopy.trustItems.map((item) => (
              <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
                <div class="text-3xl font-extrabold text-white">{item.value}</div>
                <p class="mt-2 text-sm leading-6 text-slate-200">{item.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-[1280px] px-4 py-16 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-orange">{portalCopy.categoriesTitle}</p>
        <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-brand-navy sm:text-4xl">{copy.products.title}</h2>
        <p class="mt-4 text-base leading-8 text-slate-600">{portalCopy.categoriesDescription}</p>
      </div>
      <div class="mt-10 grid gap-8 lg:grid-cols-3">
        {portalCopy.categories.map((category) => (
          <article class="overflow-hidden rounded-[28px] border border-slate-200 bg-white text-slate-900 shadow-sm">
            <div class="h-56 bg-slate-200 bg-cover bg-center" style={`background-image: linear-gradient(180deg, rgba(15,39,68,0.12), rgba(15,39,68,0.58)), url('${category.image}')`}></div>
            <div class="p-7">
              <h3 class="text-2xl font-bold text-brand-navy">{category.title}</h3>
              <p class="mt-4 text-sm leading-7 text-slate-600">{category.description}</p>
              <a href={getLocalizedPath(lang, category.href)} class="mt-6 inline-flex items-center text-sm font-semibold text-primary-700 transition hover:text-primary-800">{portalCopy.explore}</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="border-y border-slate-200 bg-white">
      <div class="mx-auto max-w-[1280px] px-4 py-16 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-orange">{portalCopy.articlesTitle}</p>
          <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-brand-navy sm:text-4xl">{copy.blog.title}</h2>
          <p class="mt-4 text-base leading-8 text-slate-600">{portalCopy.articlesDescription}</p>
        </div>
        <div class="mt-10 grid gap-8 lg:grid-cols-3">
          {portalCopy.articles.map((article) => (
            <article class="overflow-hidden rounded-[28px] border border-slate-200 bg-slate-50 text-slate-900 shadow-sm">
              <div class="h-48 bg-slate-200 bg-cover bg-center" style={`background-image: url('${article.image}')`}></div>
              <div class="p-7">
                <h3 class="text-xl font-bold leading-8 text-brand-navy">{article.title}</h3>
                <p class="mt-4 text-sm leading-7 text-slate-600">{article.description}</p>
                <a href={getLocalizedPath(lang, article.href)} class="mt-6 inline-flex items-center text-sm font-semibold text-primary-700 transition hover:text-primary-800">{portalCopy.explore}</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</BaseLayout>
