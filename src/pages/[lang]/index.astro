      { value: '72h', label: 'proposal turnaround for standard requests' }
    ],
    categoriesTitle: 'Product Series by Application',
    categoriesDescription: 'Explore the major product families with a portal-style overview before entering the detailed catalog.',
    categories: [
      { title: 'Portable Gantry Cranes', description: 'Flexible gantry systems for workshops, warehouses, and field service.', image: '/assets/images/hero.png', href: '/products' },
      { title: 'Hydraulic Lift Platforms', description: 'Stable lifting solutions for maintenance access and material positioning.', image: '/assets/images/feature-1.png', href: '/products' },
      { title: 'Custom Project Systems', description: 'Configured equipment packages for export, EPC, and distributor channels.', image: '/assets/images/feature-2.png', href: '/solutions' }
    ],
    explore: 'Explore Series',
    articlesTitle: 'Latest Articles',
    articlesDescription: 'A content matrix built for procurement education, specification comparison, and conversion support.',
    articles: [
      { title: 'How to choose the right portable gantry crane capacity', description: 'A buyer-focused framework for matching tonnage, span, and duty cycle to your real scenario.', image: '/assets/images/feature-1.png', href: '/blog' },
