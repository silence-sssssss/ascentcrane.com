      { title: 'Cómo elegir la capacidad correcta de una grúa pórtico portátil', description: 'Un marco práctico para relacionar capacidad, luz y ciclo de trabajo.', image: getBlogImage(homeArticleSlugs.safety), href: `/blog/${homeArticleSlugs.safety}` },
      { title: 'Prioridades de mantenimiento para equipos hidráulicos', description: 'Qué inspeccionar primero para reducir paradas y prolongar la vida útil.', image: getBlogImage(homeArticleSlugs.maintenance), href: `/blog/${homeArticleSlugs.maintenance}` },
      { title: 'Qué debe confirmar un comprador internacional antes de ordenar', description: 'Una guía de verificación para documentos, normas, alimentación y envío.', image: getBlogImage(homeArticleSlugs.digitalization), href: `/blog/${homeArticleSlugs.digitalization}` }
    ],
