      { title: '便携式龙门吊系列', description: '适用于车间、仓库与现场服务的灵活龙门吊系统。', image: '/assets/images/hero.png', href: '/products' },
      { title: '液压升降平台系列', description: '适用于检修作业和物料定位的稳定升降方案。', image: '/assets/images/feature-1.png', href: '/products' },
      { title: '定制项目系统', description: '面向出口、EPC 与经销渠道的成套化配置设备。', image: '/assets/images/feature-2.png', href: '/solutions' }
    ],
    explore: '查看系列',
    articlesTitle: '最新文章',
    articlesDescription: '围绕采购教育、参数比较与商业转化搭建的内容矩阵。',
    articles: [
      { title: '如何选择合适的便携式龙门吊吨位', description: '从吨位、跨度和工况出发，快速匹配真实应用场景。', image: '/assets/images/feature-1.png', href: '/blog' },
      { title: '液压升降设备的维护优先级', description: '帮助工业团队识别关键检查项，减少停机并延长设备寿命。', image: '/assets/images/feature-2.png', href: '/blog' },
