  {
    mark: 'B2B',
    accent: 'from-sky-500 via-blue-600 to-indigo-700',
    href: 'https://b2b.baidu.com/shop/32919567?fid=0%2C1775471920846&pi=b2b.land....7325104072624709'
  },
  {
