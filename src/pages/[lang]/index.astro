    articles: [
      { title: 'Wie wählt man die richtige Tragfähigkeit eines Portalkrans', description: 'Ein praxisnahes Raster für Tragfähigkeit, Spannweite und Einsatzprofil.', image: '/assets/images/feature-1.png', href: '/blog' },
      { title: 'Wartungsprioritäten für hydraulische Hebetechnik', description: 'Welche Punkte Teams zuerst prüfen sollten, um Stillstand zu vermeiden.', image: '/assets/images/feature-2.png', href: '/blog' },
      { title: 'Was internationale Käufer vor der Bestellung prüfen sollten', description: 'Checkliste zu Dokumentation, Standards, Stromversorgung und Versand.', image: '/assets/images/hero.png', href: '/blog' }
    ]
  },
  fr: {
    trustTitle: 'Confiance & chiffres',
    trustItems: [
      { value: '36+', label: 'marchés export servis' },
      { value: '1200+', label: 'projets de levage livrés' },
      { value: '72h', label: 'pour une proposition standard' }
    ],
    categoriesTitle: 'Séries produits par application',
    categoriesDescription: 'Explorez les grandes familles de produits dans une logique portail avant d’entrer dans le catalogue détaillé.',
    categories: [
      { title: 'Portiques mobiles', description: 'Systèmes de portiques flexibles pour ateliers, entrepôts et interventions terrain.', image: '/assets/images/hero.png', href: '/products' },
      { title: 'Plateformes hydrauliques', description: 'Solutions stables pour maintenance en hauteur et positionnement matière.', image: '/assets/images/feature-1.png', href: '/products' },
      { title: 'Systèmes projet sur mesure', description: 'Packages configurés pour l’export, les projets EPC et les distributeurs.', image: '/assets/images/feature-2.png', href: '/solutions' }
    ],
    explore: 'Explorer la série',
    articlesTitle: 'Latest Articles',
    articlesDescription: 'Une matrice de contenu pensée pour l’éducation achat, la comparaison technique et la conversion.',
