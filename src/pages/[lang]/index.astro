    articles: [
      { title: 'Как выбрать правильную грузоподъемность мобильного крана', description: 'Практический подход к выбору грузоподъемности, пролета и режима работы.', image: '/assets/images/feature-1.png', href: '/blog' },
      { title: 'Приоритеты обслуживания гидравлического подъемного оборудования', description: 'Ключевые проверки для сокращения простоев и продления срока службы.', image: '/assets/images/feature-2.png', href: '/blog' },
      { title: 'Что нужно подтвердить перед международным заказом', description: 'Контрольный список по документам, стандартам, питанию и логистике.', image: '/assets/images/hero.png', href: '/blog' }
    ]
  },
  de: {
    trustTitle: 'Vertrauen & Kennzahlen',
    trustItems: [
      { value: '36+', label: 'bediente Exportmärkte' },
      { value: '1200+', label: 'realisierte Hebeprojekte' },
      { value: '72h', label: 'für Standardangebote' }
    ],
    categoriesTitle: 'Produktserien nach Anwendung',
    categoriesDescription: 'Verschaffen Sie sich zuerst einen portalartigen Überblick über die Kernserien und wechseln Sie dann in den Detailkatalog.',
    categories: [
      { title: 'Mobile Portalkrane', description: 'Flexible Kransysteme für Werkstätten, Lager und Außeneinsatz.', image: '/assets/images/hero.png', href: '/products' },
      { title: 'Hydraulische Hebebühnen', description: 'Stabile Hebelösungen für Wartung und Materialpositionierung.', image: '/assets/images/feature-1.png', href: '/products' },
