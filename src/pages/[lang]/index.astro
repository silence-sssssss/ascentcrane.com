      { title: 'Wie wählt man die richtige Tragfähigkeit eines Portalkrans', description: 'Ein praxisnahes Raster für Tragfähigkeit, Spannweite und Einsatzprofil.', image: getBlogImage(homeArticleSlugs.safety), href: `/blog/${homeArticleSlugs.safety}` },
