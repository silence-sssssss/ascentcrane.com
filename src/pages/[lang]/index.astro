const portalCopy = homePortalCopy[lang];
const imageAspectRatios: Record<string, string> = {
  '/assets/images/hero.png': '1064 / 832',
  '/assets/images/feature-1.png': '2200 / 1600',
  '/assets/images/feature-2.png': '2200 / 1600'
};
const getImageAspectRatio = (imagePath: string) => imageAspectRatios[imagePath] ?? '4 / 3';
const verifiedPlatformsCopy = {
