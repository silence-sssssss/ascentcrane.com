---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getAllLangStaticPaths, getLocalizedPath, siteCopy, type SiteLang } from '../../data/i18n';

export function getStaticPaths() {
  return getAllLangStaticPaths();
}

const { lang } = Astro.params as { lang: SiteLang };
const copy = siteCopy[lang];
---

<BaseLayout
  lang={lang}
  pathname="/"
  title={copy.home.title}
  description={copy.home.description}
  canonicalURL={`https://ascentcrane.com${getLocalizedPath(lang, '/')}`}
  ogImage="https://ascentcrane.com/assets/images/hero.png"
>
  <Navbar lang={lang} currentPath={Astro.url.pathname} />
  <main>
    <section class="bg-white">
      <div class="grid max-w-screen-xl px-4 pt-20 pb-8 mx-auto lg:gap-8 xl:gap-0 lg:py-16 lg:grid-cols-12 lg:pt-28">
        <div class="mr-auto place-self-center lg:col-span-7">
          <span class="inline-flex items-center rounded-full bg-orange-50 px-3 py-1 text-sm font-medium text-brand-orange ring-1 ring-inset ring-orange-200">{copy.home.eyebrow}</span>
          <h1 class="max-w-2xl mt-6 mb-4 text-4xl font-extrabold leading-none tracking-tight text-brand-navy md:text-5xl xl:text-6xl">{copy.home.title}</h1>
          <p class="max-w-2xl mb-6 font-light text-slate-600 lg:mb-8 md:text-lg lg:text-xl">{copy.home.description}</p>
          <div class="space-y-4 sm:flex sm:space-y-0 sm:space-x-4">
            <a href={getLocalizedPath(lang, '/products')} class="inline-flex items-center justify-center w-full px-5 py-3 text-sm font-medium text-center text-white rounded-lg sm:w-auto bg-brand-orange hover:bg-orange-600 focus:ring-4 focus:ring-orange-200">{copy.home.primaryCta}</a>
            <a href={getLocalizedPath(lang, '/contact')} class="inline-flex items-center justify-center w-full px-5 py-3 text-sm font-medium text-center text-slate-900 bg-white border border-slate-200 rounded-lg sm:w-auto hover:bg-slate-100 focus:ring-4 focus:ring-slate-100">{copy.home.secondaryCta}</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</BaseLayout>
