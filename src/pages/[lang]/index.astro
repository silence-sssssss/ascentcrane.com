---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import HeroCarousel from '../../components/HeroCarousel.astro';
import ExportFeatures from '../../components/ExportFeatures.astro';
import GlobalReach from '../../components/GlobalReach.astro';
import { getAllLangStaticPaths, getLocalizedPath, siteCopy, type SiteLang } from '../../data/i18n';
import { getBlogImage, getSolutionImage } from '../../data/contentMedia';
import { getMappedContentImage } from '../../data/imageAssets';

export function getStaticPaths() {
  return getAllLangStaticPaths();
}

const { lang } = Astro.params as { lang: SiteLang };
const copy = siteCopy[lang];
const homeProductImages = {
  gantry: '/assets/images/products/mobile-warehouse-gantry-crane-01.webp',
  lifts: '/assets/images/products/chain-driven-hydraulic-cargo-lift-01.webp',
  solutions: getSolutionImage('manufacturing-assembly-line-lift')
} as const;
const homeArticleSlugs = {
  safety: '2025-safety-guide-for-portable-gantry-cranes',
  maintenance: 'maintenance-tips-for-hydraulic-scissor-lifts',
  digitalization: 'how-digitalization-improves-lifting-efficiency'
} as const;
const homePortalCopy = {
  en: {
    trustTitle: 'Trust & Figures',
