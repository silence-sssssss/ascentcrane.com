const detailText = detailCopy[lang];
const specificationRows = [
  { label: detailText.tonnage, value: tonnage },
  { label: detailText.span, value: span },
  { label: detailText.liftingHeight, value: liftingHeight },
  { label: detailText.powerSource, value: powerSource },
  { label: detailText.model, value: model }
];
const tocItems = [
  { id: 'overview', text: detailText.eyebrow, level: 2 },
  { id: 'content-body', text: title, level: 2 },
  { id: 'specifications', text: detailText.specs, level: 2 },
  { id: 'quote-form', text: detailText.quote, level: 2 }
] as const;
const breadcrumbItems = [
  { label: detailText.home, href: getLocalizedPath(lang, '/') },
  { label: detailText.products, href: getLocalizedPath(lang, '/products') },
  { label: getProductCategoryLabel(lang, productCategory), href: `${getLocalizedPath(lang, '/products')}#${getProductCategoryAnchor(productCategory)}` },
  { label: title }
];
const categoryItems = productCategoryOrder.map((item) => ({
  category: item,
  label: getProductCategoryLabel(lang, item),
  href: `${getLocalizedPath(lang, '/products')}#${getProductCategoryAnchor(item)}`,
  active: item === productCategory
}));

---

<ProductLayout
  lang={lang}
  pathname={`/products/${slug}`}
  title={`${title} | Ascent Crane Product Detail`}
  description={description}
  canonicalURL={`https://ascentcrane.com${getLocalizedPath(lang, `/products/${slug}`)}`}
  ogImage={`https://ascentcrane.com${heroImage}`}
  heroEyebrow={detailText.eyebrow}
  heroTitle={title}
  heroDescription={description}
  tocItems={tocItems}
  ctaCopy={{
    tocTitle: detailText.tocTitle,
    getQuote: `${detailText.quote} ${title}`,
    readyTitle: detailText.readyTitle,
    readyText: detailText.readyText,
    whatsappLabel: detailText.whatsappLabel,
    categoriesTitle: detailText.categoriesTitle
  }}
  breadcrumbItems={breadcrumbItems}
  categoryItems={categoryItems}
  stickyLabel={title}
  pageType="product"
  product={{ name: title, model, image: heroImage, description, sku: model, availability: stockStatus, price, priceCurrency }}
>
  <section id="overview">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-orange">{detailText.eyebrow}</p>
        <h2 class="mt-3 text-2xl font-bold text-brand-navy">{title}</h2>
      </div>
      <a href={getLocalizedPath(lang, '/contact')} class="inline-flex items-center justify-center rounded-xl border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-50 hover:text-slate-900 focus:text-slate-900">{detailText.contact}</a>
    </div>
  </section>

  <article id="content-body" class="prose prose-slate mt-10 max-w-none prose-headings:scroll-mt-28 prose-headings:text-brand-navy prose-a:text-primary-700">
    <Content />
  </article>

  <section class="mt-10 grid gap-6">
    <div class="h-64 rounded-[24px] border border-slate-200 bg-slate-100 shadow-sm"></div>
    <div class="h-64 rounded-[24px] border border-slate-200 bg-slate-100 shadow-sm"></div>
  </section>

  <section id="specifications" class="mt-12">
    <SpecTable rows={specificationRows} title={detailText.specs} />
  </section>

  <section id="quote-form" class="mt-12">
    <ContactForm productName={title} lang={lang} />
  </section>
</ProductLayout>
