---
import { Image } from 'astro:assets';
import ProductLayout from '../../../layouts/ProductLayout.astro';
import DataSheetTable from '../../../components/DataSheetTable.astro';
import ContactForm from '../../../components/ContactForm.astro';
import { supportedLangs, getLocalizedPath, localizeProductFieldValue, type SiteLang } from '../../../data/i18n';
import { getProductCategoryAnchor, getProductCategoryLabel, productCategoryOrder, type ProductCategory } from '../../../data/productCategories';
import { getMappedProductGalleryImage } from '../../../data/imageAssets';

export async function getStaticPaths() {
  const productModules = import.meta.glob('../../../content/products/**/*.md');
  const entries = await Promise.all(
    Object.values(productModules).map(async (resolver) => {
      const mod = (await resolver()) as {
        frontmatter: Record<string, string>;
        default: unknown;
      };

      return {
        data: mod.frontmatter,
        Content: mod.default
      };
    })
  );

  return entries
    .filter((entry) => supportedLangs.includes(entry.data.lang as SiteLang))
    .map((entry) => ({
      params: { lang: entry.data.lang, slug: entry.data.slug },
      props: { product: entry }
    }));
}

const { lang, slug } = Astro.params as { lang: SiteLang; slug: string };
const { product } = Astro.props as {
  product: {
    data: Record<string, string>;
  };
};
const { title, description, model, stockStatus, price, priceCurrency, heroImage, category, galleryImages = [], tableHeaders = [], tableRows = [] } = product.data as Record<string, unknown> & {
  title: string;
  description: string;
  model: string;
  stockStatus: string;
  price: string;
  priceCurrency: string;
  heroImage: string;
  category: string;
  galleryImages?: string[];
  tableHeaders?: string[];
  tableRows?: string[][];
};
const productCategory = category as ProductCategory;
const detailCopy = {
  en: {
    eyebrow: 'Product Detail',
    quote: 'Request Quote for',
    contact: 'Contact Crane Sales Team',
    excelTable: 'Factory Specification Table',
    tocTitle: 'Content',
    readyTitle: 'Ready to Start?',
    readyText: 'Share your project scope, destination market, and required specifications to get a structured quotation path.',
    categoriesTitle: 'Product Categories',
    home: 'Home',
    products: 'Products'
  },
  zh: {
    eyebrow: '产品详情',
    quote: '获取以下产品报价：',
    contact: '联系起重设备销售团队',
    excelTable: 'Excel 原始规格表',
    tocTitle: '内容',
    readyTitle: '准备开始？',
    readyText: '分享您的项目范围、目的地市场和所需的技术参数，以获得结构化的报价路径。',
    categoriesTitle: '产品分类',
    home: '首页',
    products: '产品中心'
  },
  ru: {
    eyebrow: 'Детали продукта',
    quote: 'Запросить предложение на',
    contact: 'Связаться с отделом продаж',
    excelTable: 'Таблица заводских спецификаций',
    tocTitle: 'Содержание',
    readyTitle: 'Готовы начать?',
    readyText: 'Поделитесь своим проектом, целевым рынком и необходимыми техническими характеристиками, чтобы получить структурированный путь к котировке.',
    categoriesTitle: 'Категории продукции',
    home: 'Главная',
    products: 'Продукция'
  },
  de: {
    eyebrow: 'Produktdetail',
    quote: 'Angebot anfordern für',
    contact: 'Kran-Vertrieb kontaktieren',
    excelTable: 'Werksspezifikationstabelle',
    tocTitle: 'Inhalt',
    readyTitle: 'Bereit zu beginnen?',
    readyText: 'Teilen Sie Ihr Projekt, Zielmarkt und erforderliche technische Daten, um einen strukturierten Angebotsweg zu erhalten.',
    categoriesTitle: 'Produktkategorien',
    home: 'Startseite',
    products: 'Produkte'
  },
  fr: {
    eyebrow: 'Détail produit',
    quote: 'Demander un devis pour',
    contact: 'Contacter l’équipe commerciale',
    excelTable: 'Tableau des spécifications usine',
    tocTitle: 'Contenu',
    readyTitle: 'Prêt à commencer?',
    readyText: 'Partagez votre projet, votre marché cible et vos spécifications techniques requises pour obtenir un chemin de devis structuré.',
    categoriesTitle: 'Catégories de produits',
    home: 'Accueil',
    products: 'Produits'
  },
  es: {
    eyebrow: 'Detalle del producto',
    quote: 'Solicitar cotización para',
    contact: 'Contactar al equipo comercial',
    excelTable: 'Tabla de especificaciones de fábrica',
    tocTitle: 'Contenido',
    readyTitle: '¿Listo para empezar?',
    readyText: 'Comparta su proyecto, mercado de destino y especificaciones técnicas requeridas para obtener un camino de cotización estructurado.',
    categoriesTitle: 'Categorías de productos',
    home: 'Inicio',
    products: 'Productos'
  }
} as const;
const detailText = detailCopy[lang];
const localizedModel = localizeProductFieldValue(lang, model);
const tocItems = [
  { id: 'overview', text: detailText.eyebrow, level: 2 },
  { id: 'excel-spec-table', text: detailText.excelTable, level: 2 },
  { id: 'quote-form', text: detailText.quote, level: 2 }
] as const;
const breadcrumbItems = [
  { label: detailText.home, href: getLocalizedPath(lang, '/') },
  { label: detailText.products, href: getLocalizedPath(lang, '/products') },
  { label: getProductCategoryLabel(lang, productCategory), href: `${getLocalizedPath(lang, '/products')}#${getProductCategoryAnchor(productCategory)}` },
  { label: title }
];
const categoryItems = productCategoryOrder.map((item) => ({
  category: item,
  label: getProductCategoryLabel(lang, item),
  href: `${getLocalizedPath(lang, '/products')}#${getProductCategoryAnchor(item)}`,
  active: item === productCategory
}));

---

<ProductLayout
  lang={lang}
  pathname={`/products/${slug}`}
  title={`${title} | Ascent Crane Product Detail`}
  description={description}
  canonicalURL={`https://ascentcrane.com${getLocalizedPath(lang, `/products/${slug}`)}`}
  ogImage={`https://ascentcrane.com${heroImage}`}
  heroEyebrow={detailText.eyebrow}
  heroTitle={title}
  heroDescription={description}
  tocItems={tocItems}
  ctaCopy={{
    tocTitle: detailText.tocTitle,
    getQuote: `${detailText.quote} ${title}`,
    readyTitle: detailText.readyTitle,
    readyText: detailText.readyText,
    categoriesTitle: detailText.categoriesTitle
  }}
  breadcrumbItems={breadcrumbItems}
  categoryItems={categoryItems}
  stickyLabel={title}
  pageType="product"
  product={{ name: title, model: localizedModel, image: heroImage, description, sku: localizedModel, availability: stockStatus, price, priceCurrency, category: productCategory }}
>
  <section id="overview">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="industrial-eyebrow">{detailText.eyebrow}</p>
        <h2 class="mt-3 text-2xl font-extrabold tracking-tight text-brand-navy">{title}</h2>
      </div>
      <a href={getLocalizedPath(lang, '/contact')} class="inline-flex items-center justify-center border border-slate-300 px-5 py-3 text-sm font-bold uppercase tracking-[0.08em] text-slate-900 transition hover:bg-slate-100 hover:text-slate-900">{detailText.contact}</a>
    </div>
    <div class="mt-6 border border-slate-200 bg-white px-6 py-5 text-base leading-8 text-slate-600">
      {description}
    </div>
    {galleryImages.length > 0 && (
      <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {galleryImages.map((image, index) => (
          <div class="overflow-hidden border border-slate-200 bg-white">
            <Image src={getMappedProductGalleryImage(image)} alt={`${title} product image ${index + 1}`} class="h-64 w-full object-cover" format="avif" quality="mid" widths={[400,800,1200]} sizes="(min-width: 1280px) 20vw, (min-width: 768px) 45vw, 100vw" width={1200} height={800} loading="lazy" />
          </div>
        ))}
      </div>
    )}
  </section>

  <section id="excel-spec-table" class="mt-12">
    <DataSheetTable lang={lang} title={detailText.excelTable} headers={tableHeaders} rows={tableRows} />
  </section>

  <section id="quote-form" class="mt-12">
    <ContactForm productName={title} lang={lang} />
  </section>
</ProductLayout>
