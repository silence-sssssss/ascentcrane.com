---
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { getAllLangStaticPaths, getLocalizedPath, localizeProductFieldValue, siteCopy, type SiteLang } from '../../../data/i18n';
import { getProductCategoryAnchor, getProductCategoryDescription, getProductCategoryLabel, productCategoryOrder, type ProductCategory } from '../../../data/productCategories';
import { getMappedProductHeroImage } from '../../../data/imageAssets';

export function getStaticPaths() {
  return getAllLangStaticPaths();
}

const productModules = import.meta.glob('../../../content/products/**/*.md', { eager: true });
const { lang } = Astro.params as { lang: SiteLang };
const copy = siteCopy[lang];
const productListCopy = {
  en: {
    cta: 'View Details',
    heroTag: 'Portal Catalog', heroStats: ['5 core product lines', '6 languages', 'Export-ready documentation'],
    featuredTitle: 'Industrial Product Portfolio', featuredText: 'Explore our core lifting products engineered for export delivery, reliable performance, and long-term industrial service.',
    directoryTitle: 'Product Category Directory',
    directoryText: 'Browse our main product families and discover lifting solutions built for factories, warehouses, construction, and export projects.',
    categoryNavTitle: 'Categories',
    countSuffix: 'products'
  },
  zh: {
    cta: '查看详情',
    heroTag: '产品矩阵', heroStats: ['5 大核心产品线', '6 种语言', '出口型资料齐备'],
    featuredTitle: '工业产品矩阵', featuredText: '集中展示企业主力起重与升降设备产品，突出出口交付能力、工业可靠性与持续服务保障。',
    directoryTitle: '产品分类目录',
    directoryText: '浏览企业核心产品系列，快速了解面向工厂、仓储、工程与海外项目的成熟设备方案。',
    categoryNavTitle: '分类导航',
    countSuffix: '个产品'
  },
  ru: {
    cta: 'Смотреть подробнее',
    heroTag: 'Портальный каталог', heroStats: ['5 ключевых продуктовых линий', '6 языков', 'Экспортная документация'],
    featuredTitle: 'Промышленный каталог продукции', featuredText: 'Ознакомьтесь с нашей ключевой линейкой подъемного оборудования, рассчитанной на надежную эксплуатацию и экспортные поставки.',
    directoryTitle: 'Каталог категорий продукции',
    directoryText: 'Изучите основные продуктовые направления компании и подберите решения для производства, склада, стройки и экспортных проектов.',
    categoryNavTitle: 'Категории',
    countSuffix: 'товаров'
  },
  de: {
    cta: 'Details ansehen',
    heroTag: 'Portal-Katalog', heroStats: ['5 Kernproduktlinien', '6 Sprachen', 'Exportfähige Unterlagen'],
    featuredTitle: 'Industrielles Produktportfolio', featuredText: 'Entdecken Sie unsere wichtigsten Hebeprodukte für verlässliche Industrieeinsätze, Exportprojekte und langfristige Nutzung.',
    directoryTitle: 'Produktkategorien-Verzeichnis',
    directoryText: 'Verschaffen Sie sich einen Überblick über die wichtigsten Produktfamilien für Werk, Lager, Baustelle und internationale Projekte.',
    categoryNavTitle: 'Kategorien',
    countSuffix: 'Produkte'
  },
  fr: {
    cta: 'Voir le détail',
    heroTag: 'Catalogue portail', heroStats: ['5 gammes principales', '6 langues', 'Documentation export prête'],
    featuredTitle: 'Portefeuille de produits industriels', featuredText: 'Découvrez nos équipements phares de levage et d’accès conçus pour la fiabilité industrielle et les projets export.',
    directoryTitle: 'Répertoire des catégories produits',
    directoryText: 'Parcourez les principales familles de produits et identifiez des solutions adaptées aux usines, entrepôts, chantiers et projets internationaux.',
    categoryNavTitle: 'Catégories',
    countSuffix: 'produits'
  },
  es: {
    cta: 'Ver detalles',
    heroTag: 'Catálogo portal', heroStats: ['5 líneas principales', '6 idiomas', 'Documentación lista para exportación'],
    featuredTitle: 'Portafolio industrial de productos', featuredText: 'Conozca nuestros equipos principales de elevación diseñados para rendimiento confiable, entrega exportadora y servicio industrial continuo.',
    directoryTitle: 'Directorio de categorías de producto',
    directoryText: 'Revise las principales familias de producto y encuentre soluciones para fábricas, almacenes, construcción y proyectos de exportación.',
    categoryNavTitle: 'Categorías',
    countSuffix: 'productos'
  }
} as const;
const productListText = productListCopy[lang];
const products = Object.values(productModules)
  .map((module) => (module as { frontmatter: Record<string, string> }).frontmatter as Record<string, string> & { category: ProductCategory })
  .filter((product) => product.lang === lang);
const categoryGroups = productCategoryOrder.map((category) => ({
  category,
  anchorId: getProductCategoryAnchor(category),
  label: getProductCategoryLabel(lang, category),
  description: getProductCategoryDescription(lang, category),
  products: products.filter((product) => product.category === category)
}));
---

<BaseLayout
  lang={lang}
  pathname="/products"
  title={`Products | ${copy.products.title}`}
  description={copy.products.description}
  canonicalURL={`https://ascentcrane.com${getLocalizedPath(lang, '/products')}`}
  ogImage="https://ascentcrane.com/assets/images/hero.png"
>
  <Navbar lang={lang} currentPath={Astro.url.pathname} />
  <main class="bg-brand-cold pt-28">
    <section class="border-b border-slate-300 bg-white">
      <div class="mx-auto grid max-w-[1280px] gap-0 px-4 py-0 lg:grid-cols-[1.1fr_0.9fr] lg:px-8">
        <div class="py-16 lg:py-20 lg:pr-10">
          <p class="industrial-eyebrow">{copy.products.eyebrow}</p>
          <h1 class="mt-4 text-4xl font-extrabold tracking-tighter text-brand-navy sm:text-5xl">{copy.products.title}</h1>
          <p class="mt-5 text-lg leading-8 text-slate-600">{copy.products.description}</p>
        </div>
        <div class="border-t border-slate-200 bg-brand-navy text-white lg:border-l lg:border-t-0 lg:border-slate-200">
          <div class="p-8 lg:p-10">
            <p class="text-xs font-bold uppercase tracking-[0.24em] text-brand-yellow">{productListText.heroTag}</p>
            <h2 class="mt-4 text-2xl font-extrabold tracking-tight">{productListText.featuredTitle}</h2>
            <p class="mt-3 text-sm leading-7 text-slate-200">{productListText.featuredText}</p>
            <div class="mt-6 grid gap-px border border-white/15 bg-white/10 sm:grid-cols-3 lg:grid-cols-1 xl:grid-cols-3">
              {productListText.heroStats.map((stat) => (
                <div class="bg-brand-navy px-4 py-4 text-sm font-semibold uppercase tracking-[0.08em] text-slate-100">{stat}</div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-[1280px] px-4 py-14 lg:px-8 lg:py-16">
      <div class="grid gap-10 xl:grid-cols-[240px_minmax(0,1fr)]">
        <aside>
          <div class="xl:sticky xl:top-28 border border-slate-200 bg-white p-6 text-slate-900">
            <p class="industrial-eyebrow">{productListText.categoryNavTitle}</p>
            <h2 class="mt-4 text-2xl font-extrabold tracking-tight text-brand-navy">{productListText.directoryTitle}</h2>
            <p class="mt-4 text-sm leading-7 text-slate-600">{productListText.directoryText}</p>
            <div class="mt-6 grid gap-px border border-slate-200 bg-slate-200 sm:grid-cols-2 xl:grid-cols-1">
              {categoryGroups.map((group) => (
                <a href={`#${group.anchorId}`} class="bg-white px-4 py-3 text-sm font-semibold uppercase tracking-[0.06em] text-slate-700 transition hover:bg-slate-100 hover:text-slate-900">
                  <div class="flex items-center justify-between gap-4">
                    <span>{group.label}</span>
                    <span class="font-mono text-xs font-semibold text-slate-500">{group.products.length}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </aside>

        <div class="space-y-12">
          {categoryGroups.map((group) => (
            <section id={group.anchorId} class="scroll-mt-28">
              <div class="mb-8">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
                  <div>
                    <h2 class="text-3xl font-extrabold tracking-tighter text-brand-navy sm:text-4xl">{group.label}</h2>
                    <div class="mt-3 h-px w-24 bg-brand-steel"></div>
                  </div>
                  <p class="font-mono text-sm font-semibold text-slate-500">{group.products.length} {productListText.countSuffix}</p>
                </div>
                <p class="mt-4 max-w-3xl text-base leading-8 text-slate-600">{group.description}</p>
              </div>

              {group.products.length > 0 ? (
                <div class="grid gap-6 md:grid-cols-2 2xl:grid-cols-3">
                  {group.products.map((product) => (
                    <article class="overflow-hidden border border-slate-200 bg-white text-slate-900 transition hover:border-brand-navy">
                      <div class="relative h-52 border-b border-slate-200 bg-slate-300">
                        <Image src={getMappedProductHeroImage(product.heroImage)} alt={product.title} class="h-full w-full object-cover" format="avif" quality="mid" widths={[400,800,1200]} sizes="(min-width: 1536px) 22vw, (min-width: 768px) 45vw, 100vw" width={1200} height={800} loading="lazy" />
                        <div class="absolute left-0 top-0 border-r border-b border-white/20 bg-brand-navy/80 px-4 py-3 text-white">
                          <p class="text-xs font-bold uppercase tracking-[0.16em] text-brand-yellow">{localizeProductFieldValue(lang, product.model)}</p>
                        </div>
                      </div>
                      <div class="p-6">
                        <h3 class="text-2xl font-extrabold tracking-tight text-brand-navy">{product.title}</h3>
                        <a href={getLocalizedPath(lang, `/products/${product.slug}`)} class="mt-6 inline-flex items-center justify-center border border-brand-steel bg-brand-yellow px-5 py-3 text-sm font-bold uppercase tracking-[0.08em] text-brand-steel transition hover:bg-brand-orange hover:text-white">{productListText.cta}</a>
                      </div>
                    </article>
                  ))}
                </div>
              ) : (
                <div class="border border-dashed border-slate-300 bg-white px-6 py-10 text-sm text-slate-500">
                  {group.label}
                </div>
              )}
            </section>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</BaseLayout>
