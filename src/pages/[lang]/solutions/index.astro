---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { getAllLangStaticPaths, getLocalizedPath, siteCopy, type SiteLang } from '../../../data/i18n';

export function getStaticPaths() {
  return getAllLangStaticPaths();
}

const { lang } = Astro.params as { lang: SiteLang };
const copy = siteCopy[lang];
const solutionsCopy = {
  en: {
    items: [
      'Port and terminal lifting solutions',
      'Workshop and plant material handling',
      'Overseas EPC and distributor support'
    ],
    description: 'Ascent Crane adapts engineering, compliance, and delivery planning around this operating scenario.'
  },
  zh: {
    items: [
      '港口与码头吊装方案',
      '车间与工厂物料搬运',
      '海外 EPC 与经销支持'
    ],
    description: 'Ascent Crane 会围绕该应用场景调整工程方案、合规配置与交付规划。'
  },
  ru: {
    items: [
      'Подъемные решения для портов и терминалов',
      'Перемещение материалов в цехах и на заводах',
      'Поддержка зарубежных EPC и дистрибьюторов'
    ],
    description: 'Ascent Crane адаптирует проектирование, соответствие и поставку под данный сценарий эксплуатации.'
  },
  de: {
    items: [
      'Hebelösungen für Häfen und Terminals',
      'Materialhandling für Werkstatt und Produktion',
      'Support für internationale EPC- und Vertriebspartner'
    ],
    description: 'Ascent Crane passt Technik, Compliance und Lieferplanung an dieses Einsatzszenario an.'
  },
  fr: {
    items: [
      'Solutions de levage pour ports et terminaux',
      'Manutention pour ateliers et usines',
      'Support EPC international et distributeurs'
    ],
    description: 'Ascent Crane adapte l’ingénierie, la conformité et la planification de livraison à ce scénario opérationnel.'
  },
  es: {
    items: [
      'Soluciones de elevación para puertos y terminales',
      'Manipulación de materiales para taller y planta',
      'Soporte para EPC y distribuidores internacionales'
    ],
    description: 'Ascent Crane adapta ingeniería, cumplimiento y planificación de entrega según este escenario operativo.'
  }
} as const;
const solutionsText = solutionsCopy[lang];
---

<BaseLayout
  lang={lang}
  pathname="/solutions"
  title={`Solutions | ${copy.solutions.title}`}
  description={copy.solutions.description}
  canonicalURL={`https://ascentcrane.com${getLocalizedPath(lang, '/solutions')}`}
  ogImage="https://ascentcrane.com/assets/images/hero.png"
>
  <Navbar lang={lang} currentPath={Astro.url.pathname} />
  <main class="bg-white pt-28">
    <section class="mx-auto max-w-screen-xl px-4 py-16 lg:px-6 lg:py-24">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-orange">{copy.solutions.eyebrow}</p>
        <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-brand-navy sm:text-5xl">{copy.solutions.title}</h1>
        <p class="mt-5 text-lg leading-8 text-slate-600">{copy.solutions.description}</p>
      </div>
      <div class="mt-12 grid gap-8 lg:grid-cols-3">
        {solutionsText.items.map((solution) => (
          <article class="rounded-[28px] border border-slate-200 bg-slate-50 p-8 text-slate-900">
            <h2 class="text-2xl font-bold text-brand-navy">{solution}</h2>
            <p class="mt-4 text-sm leading-7 text-slate-600">{solutionsText.description}</p>
          </article>
        ))}
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</BaseLayout>
