---
import '../styles/global.css';
import SeoHead from '../components/SeoHead.astro';
import Schema from '../components/Schema.astro';
import { defaultLang, type SiteLang } from '../data/i18n';

interface ProductSchema {
  name: string;
  model?: string;
  image?: string;
  description?: string;
  sku?: string;
  availability?: string;
  price?: string;
  priceCurrency?: string;
}

interface Props {
  title?: string;
  description?: string;
  canonicalURL?: string;
  ogImage?: string;
  pageType?: 'home' | 'product';
  product?: ProductSchema;
  lang?: SiteLang;
  pathname?: string;
}

const {
  title = 'Ascent Crane | Leading Manufacturer of Micro Gantry Cranes & Lifting Platforms',
  description = 'Ascent Crane manufactures portable gantry cranes, scissor lifts, hoists, and export-ready lifting equipment for factories, warehouses, and projects.',
  canonicalURL = 'https://ascentcrane.com',
  ogImage = 'https://ascentcrane.com/assets/images/hero.png',
  pageType = 'home',
  product,
  lang = defaultLang,
  pathname = '/'
} = Astro.props;
---

<html lang={lang}>
  <head>
    <link rel="icon" href="https://ascentcrane.com/favicon.ico" type="image/x-icon">
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <SeoHead
      title={title}
      description={description}
      canonicalURL={canonicalURL}
      ogImage={ogImage}
      type={pageType === 'product' ? 'product' : 'website'}
      lang={lang}
      pathname={pathname}
    />
    <Schema pageType={pageType} canonicalURL={canonicalURL} product={product} lang={lang} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Roboto+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-brand-cold font-sans text-brand-steel antialiased selection:bg-brand-yellow selection:text-brand-steel">
    <slot />
  </body>
</html>
