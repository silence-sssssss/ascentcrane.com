---
import { defaultLang, getLocalizedSiteAddress, siteContactEmails, type SiteLang } from '../data/i18n';
import { getProductFaqEntries } from '../data/seo';
import type { ProductCategory } from '../data/productCategories';

interface ProductSchema {
  name: string;
  model?: string;
  image?: string;
  description?: string;
  sku?: string;
  availability?: string;
  price?: string;
  priceCurrency?: string;
  category?: ProductCategory;
}

interface Props {
  pageType?: 'home' | 'product';
  canonicalURL?: string;
  product?: ProductSchema;
  lang?: SiteLang;
}

const siteUrl = 'https://ascentcrane.com';
const {
  pageType = 'home',
  canonicalURL = siteUrl,
  product,
  lang = defaultLang
} = Astro.props;

const absoluteCanonical = canonicalURL.startsWith('http') ? canonicalURL : `${siteUrl}${canonicalURL}`;
const localizedAddress = getLocalizedSiteAddress(lang);

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Ascent Crane',
  url: siteUrl,
  logo: `${siteUrl}/assets/images/logo36px.png`,
  sameAs: []
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Ascent Crane',
  image: `${siteUrl}/assets/images/hero.png`,
  url: siteUrl,
  telephone: '+86 15903067111',
  email: [...siteContactEmails],
  address: {
    '@type': 'PostalAddress',
    streetAddress: localizedAddress,
    addressLocality: 'Changyuan City',
    addressRegion: 'Xinxiang, Henan',
    addressCountry: 'CN'
  },
  areaServed: ['Europe', 'Middle East', 'Southeast Asia', 'South America'],
  description: 'Manufacturer of micro gantry cranes, lifting platforms, hoists, and export-ready lifting solutions.'
};

const productSchema = product
  ? {
      '@context': 'https://schema.org',
      '@type': 'Product',
      brand: {
        '@type': 'Brand',
        name: 'Ascent Crane'
      },
      name: product.name,
      model: product.model ?? product.name,
      sku: product.sku ?? product.model ?? product.name,
      description: product.description ?? 'Industrial lifting equipment manufactured by Ascent Crane.',
      image: product.image ? (product.image.startsWith('http') ? product.image : `${siteUrl}${product.image}`) : `${siteUrl}/assets/images/hero.png`,
      offers: {
        '@type': 'Offer',
        url: absoluteCanonical,
        availability: product.availability ?? 'https://schema.org/InStock',
        priceCurrency: product.priceCurrency ?? 'USD',
        price: product.price ?? '0'
      }
    }
  : null;

const productFaqSchema = pageType === 'product' && product?.category
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: getProductFaqEntries({
        lang,
        title: product.name,
        category: product.category
      }).map((entry) => ({
        '@type': 'Question',
        name: entry.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: entry.answer
        }
      }))
    }
  : null;

const schemas = pageType === 'product' && product
  ? [organizationSchema, localBusinessSchema, productSchema, productFaqSchema].filter(Boolean)
  : [organizationSchema, localBusinessSchema];
---

{schemas.map((entry) => (
  <script type="application/ld+json" set:html={JSON.stringify(entry)}></script>
))}
