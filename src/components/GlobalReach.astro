const sectionCopy = copy[lang];
const labelSet = labels[lang];
---

<section class="border-b border-slate-200 bg-white" aria-label="Map showing Ascent Crane's global project distribution in over 50 countries">
  <div class="mx-auto max-w-[1480px] px-4 py-14 lg:px-6 lg:py-16 xl:px-8">
    <div class="max-w-3xl">
      <p class="industrial-eyebrow">{sectionCopy.eyebrow}</p>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tighter text-brand-navy sm:text-4xl">{sectionCopy.title}</h2>
      <p class="mt-4 text-base leading-8 text-slate-600">{sectionCopy.description}</p>
    </div>

    <div class="mt-10 w-full overflow-hidden">
      <div class="w-full border border-slate-200 bg-brand-cold p-2 sm:p-4 lg:p-5">
        <div class="global-stage relative w-full overflow-hidden bg-transparent">
          <Image src={globalMap} alt="World map showing Ascent Crane's project footprint" format="webp" quality={85} class="global-map-image select-none" loading="eager" />

          <div class="absolute inset-0">
            {locations.map((location, index) => (
              <div class="absolute" data-pin={location.id} style={`top:${location.top};left:${location.left};animation-delay:${index * 0.22}s;`}>
                <div class={`global-pin ${location.featured ? 'global-pin-featured' : 'global-pin-standard'}`}>
                  {location.featured && <span class="global-pin-pulse" aria-hidden="true"></span>}
                  <span class="global-pin-label">{labelSet[location.id]} ({location.projects})</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .global-stage {
    width: 100%;
  }

  .global-map-image {
    display: block;
    width: 100%;
    height: auto;
  }

  .global-pin {
    position: relative;
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    border: 1px solid #f97316;
    padding: 0.28rem 0.5rem;
    border-radius: 2px;
    background: #f97316;
    color: white;
    font-size: 0.68rem;
    font-weight: 700;
    line-height: 1;
    transform: translate(-50%, -50%);
    animation: global-reach-float 3.6s ease-in-out infinite;
    transition: transform 180ms ease, box-shadow 180ms ease, background-color 180ms ease, border-color 180ms ease;
    box-shadow: 0 10px 26px rgba(249, 115, 22, 0.25);
  }

  .global-pin::after {
    content: '';
    position: absolute;
    left: 8px;
    bottom: -5px;
    width: 8px;
    height: 8px;
    background: inherit;
    transform: rotate(45deg);
    border-right: 1px solid currentColor;
    border-bottom: 1px solid currentColor;
    opacity: 0.95;
  }

  .global-pin-label {
    position: relative;
    z-index: 1;
  }

  .global-pin-standard {
    background: #f97316;
    border-color: #f97316;
  }

  .global-pin-featured {
    background: #e11d48;
    border-color: #e11d48;
    box-shadow: 0 0 0 4px rgba(225, 29, 72, 0.14), 0 14px 32px rgba(225, 29, 72, 0.24);
  }

  .global-pin-pulse {
    position: absolute;
    inset: -6px;
    border-radius: 999px;
    background: rgba(225, 29, 72, 0.22);
    animation: global-pin-ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  @keyframes global-reach-float {
    0%,
    100% {
      transform: translate(-50%, -50%) translateY(0);
    }

    50% {
      transform: translate(-50%, -50%) translateY(-6px);
    }
  }

  @keyframes global-pin-ping {
    0% {
      transform: scale(0.92);
      opacity: 0.7;
    }

    75%,
    100% {
      transform: scale(1.45);
      opacity: 0;
    }
  }

  @media (max-width: 767px) {
    .global-pin {
      font-size: 0.56rem;
      padding: 0.22rem 0.38rem;
    }

    .global-pin::after {
      left: 6px;
      bottom: -4px;
      width: 7px;
      height: 7px;
    }
  }
</style>
