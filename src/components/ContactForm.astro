---
interface Props {
  productName?: string;
}

const { productName = '' } = Astro.props;
const formAction = 'https://formspree.io/f/your-form-id';
const subject = productName ? `Quote request for ${productName}` : 'Website inquiry from Ascent Crane';
---

<section class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-[0_20px_70px_rgba(15,39,68,0.08)] sm:p-8">
  <div class="mb-8">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-orange">Quick Inquiry</p>
    <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-brand-navy">Tell us what you need</h2>
    <p class="mt-3 max-w-2xl text-sm leading-7 text-slate-600 sm:text-base">
      This static form is wired for Formspree. Replace the placeholder endpoint with your real Formspree form ID to receive inquiries by email in real time.
    </p>
  </div>
  <form action={formAction} method="POST" class="grid gap-5 md:grid-cols-2">
    <input type="hidden" name="_subject" value={subject} />
    <input type="hidden" name="product_interest" value={productName} />
    <div>
      <label for="name" class="mb-2 block text-sm font-medium text-slate-800">Name</label>
      <input id="name" name="name" type="text" required class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-primary-500 focus:bg-white focus:ring-4 focus:ring-primary-100" placeholder="John Carter" />
    </div>
    <div>
      <label for="company" class="mb-2 block text-sm font-medium text-slate-800">Company</label>
      <input id="company" name="company" type="text" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-primary-500 focus:bg-white focus:ring-4 focus:ring-primary-100" placeholder="Carter Industrial Ltd." />
    </div>
    <div class="md:col-span-2">
      <label for="email" class="mb-2 block text-sm font-medium text-slate-800">Email</label>
      <input id="email" name="email" type="email" required class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-primary-500 focus:bg-white focus:ring-4 focus:ring-primary-100" placeholder="john@company.com" />
    </div>
    <div class="md:col-span-2">
      <label for="requirement" class="mb-2 block text-sm font-medium text-slate-800">Requirement Description</label>
      <textarea id="requirement" name="requirement" rows="6" required class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-primary-500 focus:bg-white focus:ring-4 focus:ring-primary-100" placeholder="Please share your lifting capacity, span, lifting height, quantity, destination country, and any technical requirements."></textarea>
    </div>
    <div class="md:col-span-2 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-xs leading-6 text-slate-500">
        Optional next step: you can later add Cloudflare Turnstile to this form for anti-spam protection.
      </p>
      <button type="submit" class="inline-flex items-center justify-center rounded-2xl bg-brand-orange px-6 py-3 text-sm font-semibold text-white transition hover:bg-orange-600 focus:outline-none focus:ring-4 focus:ring-orange-200">
        Send Inquiry
      </button>
    </div>
  </form>
</section>
