---
import { getLocalizedPath, type SiteLang } from '../data/i18n';

interface SlideCopy {
  title: string;
  text: string;
}

interface SlideItem {
  image: string;
  mark: string;
  copy: Record<SiteLang, SlideCopy>;
}

interface Props {
  lang: SiteLang;
}

const { lang } = Astro.props as Props;

const uiCopy = {
  en: {
    eyebrow: 'Featured Products',
    cta: 'Explore Products'
  },
  zh: {
    eyebrow: '主打产品',
    cta: '查看产品'
  },
  ru: {
    eyebrow: 'Основная продукция',
    cta: 'Смотреть продукцию'
  },
  de: {
    eyebrow: 'Top-Produkte',
    cta: 'Produkte ansehen'
  },
  fr: {
    eyebrow: 'Produits phares',
    cta: 'Voir les produits'
  },
  es: {
    eyebrow: 'Productos destacados',
    cta: 'Ver productos'
  }
} as const;

const slides: SlideItem[] = [
  {
    image: '/assets/images/banners/banner_1.jpg',
    mark: 'EH',
    copy: {
      en: { title: 'Electric Hoist', text: 'Compact lifting power for fast daily handling.' },
      zh: { title: '电动葫芦', text: '轻巧高效，工厂吊运常备。' },
      ru: { title: 'Электроталь', text: 'Компактная сила подъема для ежедневной работы.' },
      de: { title: 'Elektroseilzug', text: 'Kompakte Hubkraft für den täglichen Materialfluss.' },
      fr: { title: 'Palan électrique', text: 'Une puissance compacte pour la manutention quotidienne.' },
      es: { title: 'Polipasto eléctrico', text: 'Elevación compacta para el trabajo diario.' }
    }
  },
  {
    image: '/assets/images/banners/banner_2.jpg',
    mark: 'ML',
    copy: {
      en: { title: 'Mobile Lift Platform', text: 'Stable access support for flexible high work.' },
      zh: { title: '移动式升降平台', text: '高空作业灵活稳定。' },
      ru: { title: 'Мобильная подъемная платформа', text: 'Стабильный доступ для гибких высотных задач.' },
      de: { title: 'Mobile Hebebühne', text: 'Stabile Lösung für flexible Höhenarbeiten.' },
      fr: { title: 'Plateforme élévatrice mobile', text: 'Accès stable pour les travaux en hauteur flexibles.' },
      es: { title: 'Plataforma elevadora móvil', text: 'Acceso estable para trabajos en altura flexibles.' }
    }
  },
  {
    image: '/assets/images/banners/banner_3.jpg',
    mark: 'PU',
    copy: {
      en: { title: 'Polyurethane Buffer', text: 'Impact control that protects cranes and rails.' },
      zh: { title: '聚氨酯缓冲器', text: '耐冲击降噪，守护设备。' },
      ru: { title: 'Полиуретановый буфер', text: 'Надежная защита кранов и рельсов от удара.' },
      de: { title: 'Polyurethan-Puffer', text: 'Stoßschutz für Krane, Fahrwerke und Schienen.' },
      fr: { title: 'Tampon en polyuréthane', text: 'Protection anti-impact pour ponts et rails.' },
      es: { title: 'Amortiguador de poliuretano', text: 'Control de impacto para grúas y rieles.' }
    }
  },
  {
    image: '/assets/images/banners/banner_4.jpg',
    mark: 'MG',
    copy: {
      en: { title: 'Mobile Gantry Crane', text: 'Fast to move, quick to install, ready on site.' },
      zh: { title: '移动龙门架', text: '移动安装快，场景适应强。' },
      ru: { title: 'Мобильный козловой кран', text: 'Быстро перемещается и сразу готов к работе.' },
      de: { title: 'Mobiler Portalkran', text: 'Schnell versetzbar und zügig einsatzbereit.' },
      fr: { title: 'Portique mobile', text: 'Rapide à déplacer et prêt pour le terrain.' },
      es: { title: 'Pórtico móvil', text: 'Fácil de mover y listo para trabajar.' }
    }
  }
];

const text = uiCopy[lang];
---

<section class="hero-carousel-shell">
  <section class="hero-carousel" data-hero-carousel>
    <div class="hero-carousel__viewport">
    {slides.map((slide, index) => {
      const localized = slide.copy[lang];
      return (
        <article
          class={`hero-slide ${index === 0 ? 'is-active' : ''}`}
          data-hero-slide
          aria-hidden={index === 0 ? 'false' : 'true'}
        >
          <div class="hero-slide__media">
            <img src={slide.image} alt={localized.title} class="hero-slide__image" width="3663" height="1144" loading={index === 0 ? 'eager' : 'lazy'} />
          </div>
          <div class="hero-slide__veil"></div>
          <div class="hero-slide__grid"></div>
          <div class="hero-slide__content-wrap">
            <div class="hero-slide__content">
              <p class="hero-slide__eyebrow">{text.eyebrow}</p>
              <div class="hero-slide__mark">{slide.mark}</div>
              <h1 class="hero-slide__title">{localized.title}</h1>
              <p class="hero-slide__text">{localized.text}</p>
              <a href={getLocalizedPath(lang, '/products')} class="hero-slide__cta">{text.cta}</a>
            </div>
          </div>
        </article>
      );
    })}
    </div>

    <div class="hero-carousel__dots" aria-label="Hero carousel navigation">
      {slides.map((slide, index) => {
        const localized = slide.copy[lang];
        return (
          <button
            type="button"
            class={`hero-carousel__dot ${index === 0 ? 'is-active' : ''}`}
            data-hero-dot
            data-slide-index={index}
            aria-label={localized.title}
            aria-pressed={index === 0 ? 'true' : 'false'}
          ></button>
        );
      })}
    </div>
  </section>
</section>

<script>
  const carousels = document.querySelectorAll('[data-hero-carousel]');

  carousels.forEach((carousel) => {
    const slides = Array.from(carousel.querySelectorAll('[data-hero-slide]'));
    const dots = Array.from(carousel.querySelectorAll('[data-hero-dot]'));

    if (slides.length === 0) return;

    let activeIndex = 0;
    let timer = 0;

    const setActive = (index) => {
      activeIndex = index;

      slides.forEach((slide, slideIndex) => {
        const isActive = slideIndex === activeIndex;
        slide.classList.toggle('is-active', isActive);
        slide.setAttribute('aria-hidden', String(!isActive));
      });

      dots.forEach((dot, dotIndex) => {
        const isActive = dotIndex === activeIndex;
        dot.classList.toggle('is-active', isActive);
        dot.setAttribute('aria-pressed', String(isActive));
      });
    };

    const start = () => {
      window.clearInterval(timer);
      timer = window.setInterval(() => {
        setActive((activeIndex + 1) % slides.length);
      }, 8000);
    };

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        setActive(index);
        start();
      });
    });

    carousel.addEventListener('mouseenter', () => window.clearInterval(timer));
    carousel.addEventListener('mouseleave', start);

    setActive(0);
    start();
  });
</script>

<style>
  .hero-carousel-shell {
    display: flex;
    justify-content: center;
    padding: 0 1rem;
    background: transparent;
  }

  .hero-carousel {
    position: relative;
    overflow: hidden;
    width: min(85%, 1600px);
    background: transparent;
  }

  .hero-carousel__viewport {
    position: relative;
    aspect-ratio: 3663 / 1144;
  }

  .hero-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity 900ms ease, visibility 900ms ease;
  }

  .hero-slide.is-active {
    opacity: 1;
    visibility: visible;
    z-index: 1;
  }

  .hero-slide__media,
  .hero-slide__veil,
  .hero-slide__grid,
  .hero-slide__content-wrap {
    position: absolute;
    inset: 0;
  }

  .hero-slide__media {
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    padding: 0;
  }

  .hero-slide__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center center;
    display: block;
  }

  .hero-slide__veil {
    background:
      linear-gradient(90deg, rgba(0, 31, 63, 0.9) 0%, rgba(0, 31, 63, 0.55) 34%, rgba(0, 31, 63, 0.18) 62%, rgba(0, 31, 63, 0.08) 100%),
      linear-gradient(180deg, rgba(7, 21, 39, 0.18) 0%, rgba(7, 21, 39, 0.55) 100%);
  }

  .hero-slide__grid {
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: linear-gradient(90deg, rgba(255, 255, 255, 0.7) 0%, rgba(255, 255, 255, 0.2) 55%, transparent 100%);
    pointer-events: none;
  }

  .hero-slide__content-wrap {
    display: flex;
    align-items: center;
  }

  .hero-slide__content {
    width: min(50%, 760px);
    margin-left: clamp(1rem, 6vw, 7rem);
    padding-right: 2rem;
    color: white;
    position: relative;
    z-index: 2;
  }

  .hero-slide__eyebrow {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #f59e0b;
  }

  .hero-slide__mark {
    display: inline-flex;
    margin-top: 1rem;
    align-items: center;
    justify-content: center;
    min-width: 4.5rem;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.08);
    font-size: 1rem;
    font-weight: 900;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    backdrop-filter: blur(10px);
  }

  .hero-slide__title {
    margin: 1.25rem 0 0;
    font-size: clamp(3.25rem, 6vw, 6rem);
    font-weight: 900;
    line-height: 0.98;
    letter-spacing: -0.02em;
  }

  .hero-slide__text {
    margin: 1rem 0 0;
    max-width: 24rem;
    font-size: clamp(1rem, 1.4vw, 1.25rem);
    line-height: 1.9;
    color: rgba(241, 245, 249, 0.95);
  }

  .hero-slide__cta {
    display: inline-flex;
    margin-top: 2rem;
    align-items: center;
    justify-content: center;
    padding: 0.95rem 1.5rem;
    border-radius: 0.125rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: linear-gradient(135deg, #f97316 0%, #f59e0b 100%);
    color: #fff;
    font-size: 0.875rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: transform 200ms ease, box-shadow 200ms ease;
    box-shadow: 0 18px 40px rgba(249, 115, 22, 0.28);
  }

  .hero-slide__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 22px 50px rgba(249, 115, 22, 0.36);
  }

  .hero-carousel__dots {
    position: absolute;
    left: clamp(1rem, 6vw, 7rem);
    bottom: clamp(1rem, 3vw, 2rem);
    z-index: 3;
    display: none;
    gap: 0.75rem;
  }

  .hero-carousel__dot {
    width: 0.85rem;
    height: 0.85rem;
    border: 1px solid rgba(255, 255, 255, 0.38);
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.22);
    transition: transform 200ms ease, background-color 200ms ease, border-color 200ms ease;
  }

  .hero-carousel__dot.is-active {
    transform: scale(1.15);
    background: #f59e0b;
    border-color: #f59e0b;
  }

  @media (max-width: 900px) {
    .hero-carousel-shell {
      padding: 0;
    }

    .hero-carousel {
      width: 100%;
    }

    .hero-carousel__viewport {
      aspect-ratio: 3663 / 1144;
    }

    .hero-slide__content {
      width: auto;
      max-width: min(100% - 2rem, 38rem);
      margin-left: 1rem;
      margin-right: 1rem;
      padding-right: 0;
    }

    .hero-slide__title {
      font-size: clamp(2.35rem, 10vw, 3.8rem);
    }

    .hero-slide__text {
      max-width: 100%;
      line-height: 1.8;
    }

    .hero-carousel__dots {
      left: 1rem;
      bottom: 1rem;
    }
  }
</style>
