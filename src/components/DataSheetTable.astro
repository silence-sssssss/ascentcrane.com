  '加厚外壳': { en: 'Reinforced housing', zh: '加厚外壳', ru: 'Усиленный корпус', de: 'Verstärktes Gehäuse', fr: 'Boîtier renforcé', es: 'Carcasa reforzada' },
  '普通': { en: 'Standard', zh: '普通', ru: 'Стандарт', de: 'Standard', fr: 'Standard', es: 'Estándar' },
  '江阴款': { en: 'Jiangyin type', zh: '江阴款', ru: 'исполнение Jiangyin', de: 'Jiangyin-Ausführung', fr: 'version Jiangyin', es: 'versión Jiangyin' },
  '欧式': { en: 'European type', zh: '欧式', ru: 'европейский тип', de: 'Europäische Ausführung', fr: 'type européen', es: 'tipo europeo' },
  'hook': { en: 'hook', zh: '吊钩', ru: 'крюк', de: 'Haken', fr: 'crochet', es: 'gancho' }
} as const;

function localizeCellValue(value: string) {
  if (value === '-' || value === '') return value;

  const direct = cellValueLabels[value as keyof typeof cellValueLabels]?.[lang];
  if (direct) return direct;

  let normalized = value;

  normalized = normalized.replace(/(\d+)吨/g, (_m, qty) => {
    const tons = {
      en: `${qty} ton`,
      zh: `${qty}吨`,
      ru: `${qty} тонна`,
      de: `${qty} Ton`,
      fr: `${qty} tonne`,
      es: `${qty} tonelada`
    } as const;
    return tons[lang];
  });

  normalized = normalized.replace(/(\d+)条/g, (_m, qty) => {
    const chains = {
      en: qty,
      zh: `${qty}条`,
      ru: qty,
      de: qty,
      fr: qty,
      es: qty
    } as const;
    return chains[lang];
  });

  normalized = normalized.replace(/(\d+T)江阴款/g, (_m, qty) => {
    const labels = {
      en: `${qty} Jiangyin type`,
      zh: `${qty}江阴款`,
      ru: `${qty} исполнение Jiangyin`,
      de: `${qty} Jiangyin-Ausführung`,
      fr: `${qty} version Jiangyin`,
      es: `${qty} versión Jiangyin`
    } as const;
    return labels[lang];
  });

  normalized = normalized.replace(/欧式(\d+T)/g, (_m, qty) => {
    const labels = {
      en: `European type ${qty}`,
      zh: `欧式${qty}`,
      ru: `европейский тип ${qty}`,
      de: `Europäische Ausführung ${qty}`,
      fr: `type européen ${qty}`,
      es: `tipo europeo ${qty}`
    } as const;
    return labels[lang];
  });

  normalized = normalized.replace(/(\d+)\s*tonhook/gi, (_m, qty) => {
    const labels = {
      en: `${qty} ton hook`,
      zh: `${qty}吨吊钩`,
      ru: `крюк ${qty} тонна`,
      de: `${qty}-Tonnen-Haken`,
      fr: `crochet ${qty} tonne`,
      es: `gancho de ${qty} tonelada`
    } as const;
    return labels[lang];
  });

  normalized = normalized.replace(/(\d+)吨hook/gi, (_m, qty) => {
    const labels = {
      en: `${qty} ton hook`,
      zh: `${qty}吨吊钩`,
      ru: `крюк ${qty} тонна`,
      de: `${qty}-Tonnen-Haken`,
      fr: `crochet ${qty} tonne`,
      es: `gancho de ${qty} tonelada`
    } as const;
    return labels[lang];
  });

  normalized = normalized.replace(/（单链）/g, {
    en: ' (single chain)',
    zh: '（单链）',
    ru: ' (одна цепь)',
    de: ' (einsträngig)',
    fr: ' (chaîne simple)',
    es: ' (cadena simple)'
  }[lang]);

  normalized = normalized.replace(/（双链）/g, {
    en: ' (double chain)',
    zh: '（双链）',
    ru: ' (двойная цепь)',
    de: ' (zweisträngig)',
    fr: ' (double chaîne)',
    es: ' (doble cadena)'
  }[lang]);

  for (const [token, translations] of Object.entries(tokenLabels)) {
    normalized = normalized.replaceAll(token, translations[lang]);
  }

  return normalized.replace(/\s{2,}/g, ' ').trim();
}

const visibleHeaders = headers
  .filter((header) => String(header || '').trim() !== '')
  .map((header) => headerLabels[header as keyof typeof headerLabels]?.[lang] ?? header);
const normalizedRows = rows
  .map((row) =>
    row
      .slice(0, visibleHeaders.length)
      .map((cell) => {
        const value = String(cell ?? '').trim() || '-';
        return localizeCellValue(value);
      })
  )
  .filter((row) => row.some((cell) => cell !== '-'));
---

{visibleHeaders.length > 0 && normalizedRows.length > 0 && (
  <section class="overflow-hidden border border-slate-200 bg-white">
    {title && (
      <div class="border-b border-slate-200 bg-brand-cold px-6 py-4">
        <h3 class="text-lg font-extrabold uppercase tracking-[0.08em] text-brand-navy">{title}</h3>
      </div>
    )}
    <div class="overflow-x-auto">
      <table class="min-w-full border-collapse text-left text-sm">
        <thead class="bg-brand-navy text-white">
          <tr>
            {visibleHeaders.map((header) => (
              <th class="border-r border-white/10 px-4 py-3 text-xs font-bold uppercase tracking-[0.12em] last:border-r-0">{header}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {normalizedRows.map((row, rowIndex) => (
            <tr class={rowIndex % 2 === 0 ? 'bg-white' : 'bg-brand-cold'}>
              {row.map((cell) => (
                <td class="border-r border-t border-slate-200 px-4 py-3 font-mono text-brand-steel last:border-r-0">{cell}</td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
)}
