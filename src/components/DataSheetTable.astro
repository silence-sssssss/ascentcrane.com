  'Type portique': { en: 'Gantry Type', zh: '门式', ru: 'Портальный тип', de: 'Portalbauart', fr: 'Type portique', es: 'Tipo pórtico' },
  'Tipo pórtico': { en: 'Gantry Type', zh: '门式', ru: 'Портальный тип', de: 'Portalbauart', fr: 'Type portique', es: 'Tipo pórtico' },
  'Портальный тип': { en: 'Gantry Type', zh: '门式', ru: 'Портальный тип', de: 'Portalbauart', fr: 'Type portique', es: 'Tipo pórtico' },
