---
const footerGroups = [
  {
    title: 'Products',
    links: [
      { href: '#products', label: 'Gantry Cranes' },
      { href: '#products', label: 'Electric Hoists' },
      { href: '#products', label: 'Workstation Cranes' }
    ]
  },
  {
    title: 'Solutions',
    links: [
      { href: '#solutions', label: 'Port Handling' },
      { href: '#solutions', label: 'Factory Lifting' },
      { href: '#solutions', label: 'Overseas EPC Support' }
    ]
  },
  {
    title: 'Company',
    links: [
      { href: '#about', label: 'About AscentCrane' },
      { href: '#contact', label: 'Contact' },
      { href: '#contact', label: 'Request a Quote' }
    ]
  }
];
---

<footer class="bg-slate-50" id="about">
  <div class="mx-auto max-w-screen-xl px-4 py-12 lg:px-6 lg:py-16">
    <div class="grid gap-10 border-b border-slate-200 pb-10 md:grid-cols-[1.4fr_repeat(3,1fr)]">
      <div>
        <a href="#home" class="mb-5 flex items-center gap-3 text-2xl font-semibold text-brand-navy">
          <img src="/assets/images/logo.svg" class="h-8 w-auto" alt="AscentCrane logo" />
          AscentCrane
        </a>
        <p class="max-w-md text-sm leading-7 text-slate-600">
          AscentCrane supplies export-ready lifting equipment and technical support for industrial buyers who need dependable delivery, clear documentation, and long-term service.
        </p>
        <div class="mt-6 space-y-2 text-sm text-slate-600">
          <p>sales@ascentcrane.com</p>
          <p>+86 000 0000 0000</p>
          <p>Zhengzhou, China</p>
        </div>
      </div>
      {footerGroups.map((group) => (
        <div>
          <h3 class="mb-4 text-sm font-semibold uppercase tracking-wide text-slate-900">{group.title}</h3>
          <ul class="space-y-3 text-sm text-slate-600">
            {group.links.map((link) => (
              <li>
                <a href={link.href} class="transition hover:text-primary-700 hover:underline">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="pt-6 text-center text-sm text-slate-500">
      © 2026 AscentCrane. All rights reserved.
    </div>
  </div>
</footer>
