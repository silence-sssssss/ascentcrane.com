---
import { defaultLang, getLocalizedPath, siteCopy, type SiteLang } from '../data/i18n';

interface Props {
  lang?: SiteLang;
}

const { lang = defaultLang } = Astro.props;
const copy = siteCopy[lang];
const footerCopy = {
  en: {
    description: 'AscentCrane supplies export-ready lifting equipment and technical support for industrial buyers who need dependable delivery, clear documentation, and long-term service.',
    location: '河南省新乡市长垣市南蒲工业区纬二路35号',
    productLinks: ['Gantry Cranes', 'Electric Hoists', 'Workstation Cranes'],
    solutionLinks: ['Port Handling', 'Factory Lifting', 'Overseas EPC Support'],
    companyLinks: ['About AscentCrane', 'Contact', 'Request a Quote'],
    copyright: '\u00A9 2026 AscentCrane. All rights reserved.'
  },
  zh: {
    description: 'AscentCrane 为工业采购商提供面向出口的起重设备与技术支持，帮助客户获得稳定交付、清晰文件与长期服务保障。',
    location: '河南省新乡市长垣市南蒲工业区纬二路35号',
    productLinks: ['龙门吊', '电动葫芦', '工位起重设备'],
    solutionLinks: ['港口装卸', '工厂吊装', '海外 EPC 支持'],
    companyLinks: ['关于 AscentCrane', '联系我们', '获取报价'],
    copyright: '(c) 2026 AscentCrane。保留所有权利。'
  },
  ru: {
    description: 'AscentCrane поставляет экспортно-ориентированное подъемное оборудование и техническую поддержку для промышленных покупателей, которым важны надежная поставка, понятная документация и долгосрочный сервис.',
    location: '河南省新乡市长垣市南蒲工业区纬二路35号',
    productLinks: ['Козловые краны', 'Электрические тали', 'Рабочие крановые системы'],
    solutionLinks: ['Портовая обработка', 'Заводской подъем', 'Поддержка зарубежных EPC'],
    companyLinks: ['О компании AscentCrane', 'Контакты', 'Запросите предложение'],
    copyright: '\u00A9 2026 AscentCrane. Все права защищены.'
  },
  de: {
    description: 'AscentCrane liefert exportfähige Hebetechnik und technischen Support für industrielle Käufer, die verlässliche Lieferung, klare Dokumentation und langfristigen Service benötigen.',
    location: '河南省新乡市长垣市南蒲工业区纬二路35号',
    productLinks: ['Portalkrane', 'Elektrokettenzüge', 'Arbeitsplatzkrane'],
    solutionLinks: ['Portumschlag', 'Fabrikheben', 'Internationaler EPC-Support'],
    companyLinks: ['Über AscentCrane', 'Kontakt', 'Angebot anfordern'],
    copyright: '\u00A9 2026 AscentCrane. Alle Rechte vorbehalten.'
  },
  fr: {
    description: 'AscentCrane fournit des équipements de levage prêts pour l’export et un support technique aux acheteurs industriels qui recherchent une livraison fiable, une documentation claire et un service durable.',
    location: '河南省新乡市长垣市南蒲工业区纬二路35号',
    productLinks: ['Portiques', 'Palans électriques', 'Ponts de poste'],
    solutionLinks: ['Manutention portuaire', 'Levage industriel', 'Support EPC international'],
    companyLinks: ['À propos d’AscentCrane', 'Contact', 'Demander un devis'],
    copyright: '\u00A9 2026 AscentCrane. Tous droits réservés.'
  },
  es: {
    description: 'AscentCrane suministra equipos de elevación listos para exportación y soporte técnico para compradores industriales que necesitan entrega confiable, documentación clara y servicio a largo plazo.',
    location: '河南省新乡市长垣市南蒲工业区纬二路35号',
    productLinks: ['Grúas pórtico', 'Polipastos eléctricos', 'Grúas de puesto de trabajo'],
    solutionLinks: ['Manipulación portuaria', 'Elevación industrial', 'Soporte EPC internacional'],
    companyLinks: ['Sobre AscentCrane', 'Contacto', 'Solicitar cotización'],
    copyright: '\u00A9 2026 AscentCrane. Todos los derechos reservados.'
  }
} as const;
const footerText = footerCopy[lang];
const footerGroups = [
  {
    title: copy.footer.products,
    links: [
      { href: getLocalizedPath(lang, '/products'), label: footerText.productLinks[0] },
      { href: getLocalizedPath(lang, '/products'), label: footerText.productLinks[1] },
      { href: getLocalizedPath(lang, '/products'), label: footerText.productLinks[2] }
    ]
  },
  {
    title: copy.footer.solutions,
    links: [
      { href: getLocalizedPath(lang, '/solutions'), label: footerText.solutionLinks[0] },
      { href: getLocalizedPath(lang, '/solutions'), label: footerText.solutionLinks[1] },
      { href: getLocalizedPath(lang, '/solutions'), label: footerText.solutionLinks[2] }
    ]
  },
  {
    title: copy.footer.company,
    links: [
      { href: getLocalizedPath(lang, '/'), label: footerText.companyLinks[0] },
      { href: getLocalizedPath(lang, '/contact'), label: footerText.companyLinks[1] },
      { href: getLocalizedPath(lang, '/contact'), label: footerText.companyLinks[2] }
    ]
  }
];

---

<footer class="border-t border-brand-steel bg-white" id="about">
  <div class="mx-auto max-w-screen-xl px-4 py-12 lg:px-6 lg:py-14">
    <div class="grid gap-10 border-b border-slate-200 pb-10 md:grid-cols-[1.4fr_repeat(3,1fr)]">
      <div>
        <a href={getLocalizedPath(lang, '/')} class="mb-5 flex items-center gap-3 text-2xl font-bold tracking-tight text-brand-navy">
          <img src="/assets/images/logo36px.png" class="h-9 w-auto" alt="AscentCrane logo" />
          AscentCrane
        </a>
        <p class="max-w-md text-sm leading-7 text-slate-600">
          {footerText.description}
        </p>
        <div class="mt-6 grid gap-px border border-slate-200 bg-slate-200 text-sm">
          <p class="bg-white px-4 py-3 font-mono text-slate-700">hntzs@gmail.com</p>
          <p class="bg-white px-4 py-3 font-mono text-slate-700">+86 15903067111</p>
          <p class="bg-white px-4 py-3 font-mono text-slate-700">{footerText.location}</p>
        </div>
      </div>
      {footerGroups.map((group) => (
        <div>
          <h3 class="mb-4 text-sm font-bold uppercase tracking-[0.18em] text-brand-navy">{group.title}</h3>
          <ul class="space-y-3 text-sm text-slate-600">
            {group.links.map((link) => (
              <li>
                <a href={link.href} class="transition hover:text-brand-navy">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="pt-6 text-center font-mono text-sm text-slate-500">
      {footerText.copyright}
    </div>
  </div>
</footer>
