---
const ctaTitle = 'Ready to source the right crane system for your next project?';
const ctaDescription = 'Tell us your lifting capacity, span, duty class, and destination market. We will reply with a practical recommendation and quotation path.';
---

<section class="bg-white" id="contact">
  <div class="mx-auto max-w-screen-xl px-4 py-16 lg:px-6 lg:py-24">
    <div class="mx-auto max-w-screen-md rounded-3xl bg-brand-navy px-8 py-12 text-center shadow-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-orange-200">Project Consultation</p>
      <h2 class="mt-4 text-3xl font-extrabold leading-tight tracking-tight text-white sm:text-4xl">{ctaTitle}</h2>
      <p class="mx-auto mt-4 max-w-2xl text-base font-light text-slate-200 md:text-lg">{ctaDescription}</p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/contact" class="rounded-lg bg-brand-orange px-5 py-3 text-sm font-medium text-white transition hover:bg-orange-600 focus:outline-none focus:ring-4 focus:ring-orange-300">
          Contact Our Sales Team
        </a>
        <a href="/products" class="rounded-lg border border-white/20 px-5 py-3 text-sm font-medium text-white transition hover:bg-white/10 focus:outline-none focus:ring-4 focus:ring-white/20">
          Review Product Capabilities
        </a>
      </div>
    </div>
  </div>
</section>
