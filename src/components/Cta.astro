---
import { defaultLang, getLocalizedPath, type SiteLang } from '../data/i18n';

interface Props {
  lang?: SiteLang;
}

const { lang = defaultLang } = Astro.props;
const ctaCopy = {
  en: {
    eyebrow: 'Project Consultation',
    title: 'Ready to source the right crane system for your next project?',
    description: 'Tell us your lifting capacity, span, duty class, and destination market. We will reply with a practical recommendation and quotation path.',
    contact: 'Contact Our Sales Team',
    products: 'Review Product Capabilities'
  },
  zh: {
    eyebrow: '项目咨询',
    title: '准备为下一个项目选择合适的起重系统了吗？',
    description: '请告诉我们起重量、跨度、工作级别和目标市场，我们会回复可执行的设备建议与报价路径。',
    contact: '联系销售团队',
    products: '查看产品能力'
  },
  ru: {
    eyebrow: 'Консультация по проекту',
    title: 'Готовы подобрать подходящую крановую систему для вашего следующего проекта?',
    description: 'Сообщите грузоподъемность, пролет, режим работы и целевой рынок, и мы предложим практичную рекомендацию и путь к коммерческому предложению.',
    contact: 'Связаться с отделом продаж',
    products: 'Посмотреть возможности продукции'
  },
  de: {
    eyebrow: 'Projektberatung',
    title: 'Bereit, das passende Kransystem für Ihr nächstes Projekt auszuwählen?',
    description: 'Nennen Sie Tragfähigkeit, Spannweite, Einsatzklasse und Zielmarkt. Wir antworten mit einer praktikablen Empfehlung und einem Angebotsweg.',
    contact: 'Vertrieb kontaktieren',
    products: 'Produktfähigkeiten ansehen'
  },
  fr: {
    eyebrow: 'Conseil projet',
    title: 'Prêt à choisir le bon système de levage pour votre prochain projet ?',
    description: 'Indiquez la capacité, la portée, la classe de service et le marché cible. Nous répondrons avec une recommandation concrète et un parcours de devis.',
    contact: 'Contacter l’équipe commerciale',
    products: 'Voir les capacités produit'
  },
  es: {
    eyebrow: 'Consulta de proyecto',
    title: '¿Listo para elegir el sistema de grúa adecuado para su próximo proyecto?',
    description: 'Comparta capacidad, luz, clase de trabajo y mercado objetivo. Le responderemos con una recomendación práctica y una ruta de cotización.',
    contact: 'Contactar al equipo comercial',
    products: 'Revisar capacidades del producto'
  }
} as const;
const copy = ctaCopy[lang];
---

<section class="bg-white" id="contact">
  <div class="mx-auto max-w-screen-xl px-4 py-16 lg:px-6 lg:py-24">
    <div class="mx-auto max-w-screen-md rounded-3xl bg-brand-navy px-8 py-12 text-center shadow-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-orange-200">{copy.eyebrow}</p>
      <h2 class="mt-4 text-3xl font-extrabold leading-tight tracking-tight text-white sm:text-4xl">{copy.title}</h2>
      <p class="mx-auto mt-4 max-w-2xl text-base font-light text-slate-200 md:text-lg">{copy.description}</p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href={getLocalizedPath(lang, '/contact')} class="rounded-lg bg-brand-orange px-5 py-3 text-sm font-medium text-white transition hover:bg-orange-600 hover:text-white focus:outline-none focus:ring-4 focus:ring-orange-300 focus:text-white">
          {copy.contact}
        </a>
        <a href={getLocalizedPath(lang, '/products')} class="rounded-lg border border-white/20 px-5 py-3 text-sm font-medium text-white transition hover:bg-white/10 hover:text-white focus:outline-none focus:ring-4 focus:ring-white/20 focus:text-white">
          {copy.products}
        </a>
      </div>
    </div>
  </div>
</section>
