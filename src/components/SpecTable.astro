---
interface Props {
  rows: Array<{ label: string; value: string }>;
  title?: string;
}

const { rows = [], title } = Astro.props;
---

<div class="overflow-hidden rounded-[24px] border border-slate-200 bg-white shadow-sm">
  {title && (
    <div class="border-b border-slate-200 bg-slate-50 px-6 py-4">
      <h3 class="text-lg font-bold text-brand-navy">{title}</h3>
    </div>
  )}
  <div>
    {rows.map((row, index) => (
      <div class={`grid grid-cols-[220px_minmax(0,1fr)] border-b border-slate-200 last:border-b-0 ${index % 2 === 0 ? 'bg-white' : 'bg-slate-50/70'}`}>
        <div class="border-r border-slate-200 px-5 py-4 text-sm font-semibold text-slate-900">{row.label}</div>
        <div class="px-5 py-4 text-sm leading-7 text-slate-600">{row.value}</div>
      </div>
    ))}
  </div>
</div>
