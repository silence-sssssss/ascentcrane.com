---
interface Props {
  rows: Array<{ label: string; value: string }>;
  title?: string;
}

const { rows = [], title } = Astro.props;
---

<div class="overflow-hidden border border-slate-200 bg-white">
  {title && (
    <div class="border-b border-slate-200 bg-brand-cold px-6 py-4">
      <h3 class="text-lg font-extrabold uppercase tracking-[0.08em] text-brand-navy">{title}</h3>
    </div>
  )}
  <div>
    {rows.map((row, index) => (
      <div class={`grid grid-cols-[220px_minmax(0,1fr)] border-b border-slate-200 last:border-b-0 ${index % 2 === 0 ? 'bg-white' : 'bg-slate-50/70'}`}>
        <div class="border-r border-slate-200 px-5 py-4 text-xs font-bold uppercase tracking-[0.12em] text-slate-500">{row.label}</div>
        <div class="px-5 py-4 font-mono text-sm leading-7 text-brand-steel">{row.value}</div>
      </div>
    ))}
  </div>
</div>
