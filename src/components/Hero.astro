 ---
 import { Image } from 'astro:assets';
 import heroImage from '../assets/images/hero.png';
 ---

 <section class="bg-white">
  <div class="grid max-w-screen-xl px-4 pt-20 pb-8 mx-auto lg:gap-8 xl:gap-0 lg:py-16 lg:grid-cols-12 lg:pt-28">
    <div class="mr-auto place-self-center lg:col-span-7">
      <span class="inline-flex items-center rounded-full bg-orange-50 px-3 py-1 text-sm font-medium text-brand-orange ring-1 ring-inset ring-orange-200">
        AscentCrane Export Solutions
      </span>
      <h1 id="home" class="max-w-2xl mt-6 mb-4 text-4xl font-extrabold leading-none tracking-tight text-brand-navy md:text-5xl xl:text-6xl">
        Ascent Crane | Portable Gantry Crane & Scissor Lift Manufacturer
      </h1>
      <p class="max-w-2xl mb-6 font-light text-slate-600 lg:mb-8 md:text-lg lg:text-xl">
        We help overseas buyers source dependable gantry cranes, hoists, and custom lifting systems with engineering support, factory delivery, and export-ready documentation.
      </p>
      <div class="space-y-4 sm:flex sm:space-y-0 sm:space-x-4">
        <a href="#products" class="inline-flex items-center justify-center w-full px-5 py-3 text-sm font-medium text-center text-white rounded-lg sm:w-auto bg-brand-orange hover:bg-orange-600 focus:ring-4 focus:ring-orange-200">
          View Crane Specifications
        </a>
        <a href="#contact" class="inline-flex items-center justify-center w-full px-5 py-3 text-sm font-medium text-center text-slate-900 bg-white border border-slate-200 rounded-lg sm:w-auto hover:bg-slate-100 focus:ring-4 focus:ring-slate-100">
          Request a Custom Crane Quote
        </a>
      </div>
      <div class="mt-8 flex flex-wrap items-center gap-6 text-sm text-slate-500">
        <span>CE-focused documentation</span>
        <span>Custom voltage & standards</span>
        <span>Global shipping support</span>
      </div>
    </div>
    <div class="hidden lg:mt-0 lg:col-span-5 lg:flex">
      <Image src={heroImage} alt="AscentCrane lifting equipment hero" class="w-full object-contain" format="webp" quality="mid" loading="eager" widths={[480,720,960]} sizes="(min-width: 1024px) 40vw, 100vw" />
    </div>
  </div>
</section>
