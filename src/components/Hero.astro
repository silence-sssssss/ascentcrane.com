 ---
import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero.png';
import { defaultLang, getLocalizedPath, siteCopy, type SiteLang } from '../data/i18n';

interface Props {
  lang?: SiteLang;
}

const { lang = defaultLang } = Astro.props;
const copy = siteCopy[lang].home;
const heroMetaCopy = {
  en: ['CE-focused documentation', 'Custom voltage & standards', 'Global shipping support'],
  zh: ['面向 CE 的资料支持', '支持定制电压与标准', '全球运输支持'],
  ru: ['Документация с учетом CE', 'Индивидуальное напряжение и стандарты', 'Глобальная логистическая поддержка'],
  de: ['CE-orientierte Dokumentation', 'Individuelle Spannung und Standards', 'Weltweiter Versand-Support'],
  fr: ['Documentation orientée CE', 'Tension et normes sur mesure', 'Support logistique mondial'],
  es: ['Documentación orientada a CE', 'Voltaje y normas personalizadas', 'Soporte global de envío']
} as const;
const heroMeta = heroMetaCopy[lang];
---

<section class="bg-white">
  <div class="grid max-w-screen-xl px-4 pt-20 pb-8 mx-auto lg:gap-8 xl:gap-0 lg:py-16 lg:grid-cols-12 lg:pt-28">
    <div class="mr-auto place-self-center lg:col-span-7">
      <span class="inline-flex items-center rounded-full bg-orange-50 px-3 py-1 text-sm font-medium text-brand-orange ring-1 ring-inset ring-orange-200">
        {copy.eyebrow}
      </span>
      <h1 id="home" class="max-w-2xl mt-6 mb-4 text-4xl font-extrabold leading-none tracking-tight text-brand-navy md:text-5xl xl:text-6xl">
        {copy.title}
      </h1>
      <p class="max-w-2xl mb-6 font-light text-slate-600 lg:mb-8 md:text-lg lg:text-xl">
        {copy.description}
      </p>
      <div class="space-y-4 sm:flex sm:space-y-0 sm:space-x-4">
        <a href={getLocalizedPath(lang, '/products')} class="inline-flex items-center justify-center w-full px-5 py-3 text-sm font-medium text-center text-white rounded-lg sm:w-auto bg-brand-orange hover:bg-orange-600 hover:text-white focus:ring-4 focus:ring-orange-200 focus:text-white">
          {copy.primaryCta}
        </a>
        <a href={getLocalizedPath(lang, '/contact')} class="inline-flex items-center justify-center w-full px-5 py-3 text-sm font-medium text-center text-slate-900 bg-white border border-slate-200 rounded-lg sm:w-auto hover:bg-slate-100 hover:text-slate-900 focus:ring-4 focus:ring-slate-100 focus:text-slate-900">
          {copy.secondaryCta}
        </a>
      </div>
      <div class="mt-8 flex flex-wrap items-center gap-6 text-sm text-slate-500">
        <span>{heroMeta[0]}</span>
        <span>{heroMeta[1]}</span>
        <span>{heroMeta[2]}</span>
      </div>
    </div>
    <div class="hidden lg:mt-0 lg:col-span-5 lg:flex">
      <Image src={heroImage} alt="AscentCrane lifting equipment hero" class="w-full object-contain" format="avif" quality="mid" loading="eager" fetchpriority="high" widths={[400,800,1200]} sizes="(min-width: 1024px) 40vw, 100vw" width={1200} height={1200} />
    </div>
  </div>
</section>
